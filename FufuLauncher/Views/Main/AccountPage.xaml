<Page
    x:Class="FufuLauncher.Views.AccountPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:FufuLauncher.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:FufuLauncher.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FufuLauncher.Models"
    x:Name="RootPage"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
        <ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary x:Key="Light">
                <AcrylicBrush x:Key="SafeGlassBrush" FallbackColor="#E5FFFFFF" TintColor="#FFFFFF" TintOpacity="0.6" />
                <SolidColorBrush x:Key="SafeCardBrush" Color="#0A000000" />
                <SolidColorBrush x:Key="SafeBorderBrush" Color="#1A000000" />
                <SolidColorBrush x:Key="SafeHoverBrush" Color="#14000000" />
                <SolidColorBrush x:Key="SafeTextBrush" Color="#FF000000" />
                <SolidColorBrush x:Key="SafeSecondaryTextBrush" Color="#99000000" />
            </ResourceDictionary>
            <ResourceDictionary x:Key="Default">
                <AcrylicBrush x:Key="SafeGlassBrush" FallbackColor="#CC000000" TintColor="#000000" TintOpacity="0.15" />
                <SolidColorBrush x:Key="SafeCardBrush" Color="#14FFFFFF" />
                <SolidColorBrush x:Key="SafeBorderBrush" Color="#20FFFFFF" />
                <SolidColorBrush x:Key="SafeHoverBrush" Color="#24FFFFFF" />
                <SolidColorBrush x:Key="SafeTextBrush" Color="White" />
                <SolidColorBrush x:Key="SafeSecondaryTextBrush" Color="#B3FFFFFF" />
            </ResourceDictionary>
        </ResourceDictionary.ThemeDictionaries>

        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <helpers:BoolNegationConverter x:Key="BoolNegationConverter" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <helpers:DictionarySafeConverter x:Key="DictionarySafeConverter" />
        <converters:EmptyCountToVisibilityConverter x:Key="EmptyCountToVisibilityConverter" />

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource SafeGlassBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="{ThemeResource SafeGlassBrush}" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter x:Name="ContentPresenter"
                            AutomationProperties.AccessibilityView="Raw"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Content="{TemplateBinding Content}"
                            ContentTransitions="{TemplateBinding ContentTransitions}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed" />
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource TextFillColorTertiaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </ContentPresenter>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Name="EntranceStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="RootLayoutGrid"
                Storyboard.TargetProperty="Opacity"
                From="0"
                To="1"
                Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="RootLayoutTranslate"
                Storyboard.TargetProperty="Y"
                From="40"
                To="0"
                Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Name="AvatarEntranceStoryboard">
            <DoubleAnimation
                BeginTime="0:0:0.25"
                Storyboard.TargetName="AvatarPicture"
                Storyboard.TargetProperty="Opacity"
                From="0"
                To="1"
                Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Name="ExitStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="RootLayoutGrid"
                Storyboard.TargetProperty="Opacity"
                From="1"
                To="0"
                Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        </ResourceDictionary>
    </Page.Resources>

    <Grid
        x:Name="RootLayoutGrid"
        Opacity="0"
        RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="RootLayoutScale" ScaleX="1" ScaleY="1" />
                <TranslateTransform x:Name="RootLayoutTranslate" X="0" Y="0" />
            </TransformGroup>
        </Grid.RenderTransform>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,12,24,24" Spacing="24">
                <StackPanel
                    Margin="0,48,0,0"
                    HorizontalAlignment="Center"
                    Spacing="24"
                    Visibility="{x:Bind ViewModel.IsNotLoggedIn, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <FontIcon
                        HorizontalAlignment="Center"
                        FontSize="64"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Glyph="&#xE77B;" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="尚未登录" />
                    <Button
                        Padding="32,12"
                        HorizontalAlignment="Center"
                        Command="{x:Bind ViewModel.LoginCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="16" Glyph="&#xE710;" />
                            <TextBlock Text="{x:Bind ViewModel.LoginButtonText, Mode=OneWay}" />
                        </StackPanel>
                    </Button>

                    <StackPanel
                        Margin="0,32,0,0"
                        Spacing="12"
                        Visibility="{x:Bind ViewModel.HasSavedAccounts, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="已保存的其他账户" />
                        <ListView
                            Width="320"
                            ItemsSource="{x:Bind ViewModel.SavedAccounts, Mode=OneWay}"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:AccountInfo">
                                    <Grid Margin="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <PersonPicture
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,12,0"
                                            ProfilePicture="{x:Bind AvatarUrl}" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Text="{x:Bind Nickname}" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind GameUid}" />
                                        </StackPanel>
                                        <Button
                                            Grid.Column="2"
                                            Margin="0,0,4,0"
                                            Click="OnSwitchAccountClicked"
                                            Content="登录"
                                            FontSize="12" />
                                        <Button
                                            Grid.Column="3"
                                            Padding="8,4"
                                            Background="Transparent"
                                            Click="OnDeleteSavedAccountClicked"
                                            FontSize="12"
                                            Tag="{Binding GameUid}">
                                            <FontIcon
                                                FontSize="12"
                                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                Glyph="&#xE74D;" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="24" Visibility="{x:Bind ViewModel.IsLoggedIn, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4.5*" />
                            <ColumnDefinition Width="5.5*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" RowSpacing="24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Style="{StaticResource CardBorderStyle}" Translation="0,0,32">
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Ellipse
                                        x:Name="AvatarPicture"
                                        Width="84"
                                        Height="84"
                                        Loaded="AvatarPicture_Loaded"
                                        Opacity="0">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{x:Bind ViewModel.CurrentAccount.AvatarUrl, Mode=OneWay}" Stretch="UniformToFill" />
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="6">
                                        <StackPanel
                                            VerticalAlignment="Bottom"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Style="{StaticResource SubtitleTextBlockStyle}"
                                                Text="{x:Bind ViewModel.CurrentAccount.Nickname, Mode=OneWay}" />

                                            <Border
                                                Padding="8,2"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                                <StackPanel
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal"
                                                    Spacing="4">
                                                    <FontIcon
                                                        FontFamily="Segoe Fluent Icons"
                                                        FontSize="12"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Glyph="{x:Bind ViewModel.CurrentAccount.GenderIcon, Mode=OneWay}" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Text="{x:Bind ViewModel.CurrentAccount.GenderText, Mode=OneWay}" />
                                                </StackPanel>
                                            </Border>

                                            <Border
                                                Margin="4,0,0,0"
                                                Padding="6,2"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="10">
                                                <TextBlock
                                                    FontSize="10"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    Text="{x:Bind ViewModel.CurrentAccount.LevelDisplay, Mode=OneWay}" />
                                            </Border>
                                        </StackPanel>

                                        <TextBlock
                                            FontSize="13"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            MaxLines="1"
                                            Text="{x:Bind ViewModel.CurrentAccount.Sign, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />

                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                                <Run Text="UID:" />
                                                <Run FontWeight="SemiBold" Text="{x:Bind ViewModel.CurrentAccount.GameUidDisplay, Mode=OneWay}" />
                                            </TextBlock>

                                            <Border
                                                Width="1"
                                                Height="10"
                                                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                Text="{x:Bind ViewModel.CurrentAccount.Server, Mode=OneWay}" />

                                            <Border
                                                Width="1"
                                                Height="10"
                                                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                                            <StackPanel
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal"
                                                Spacing="4">
                                                <FontIcon
                                                    FontFamily="Segoe Fluent Icons"
                                                    FontSize="10"
                                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                    Glyph="&#xE81D;" />
                                                <TextBlock
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                    Text="{x:Bind ViewModel.CurrentAccount.IpRegion, Mode=OneWay}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                        <ProgressRing
                                            Width="20"
                                            Height="20"
                                            IsActive="{x:Bind ViewModel.IsLoadingUserInfo, Mode=OneWay}"
                                            Visibility="{x:Bind ViewModel.IsLoadingUserInfo, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Button Grid.Row="0" Style="{StaticResource ActionButtonStyle}" Translation="0,0,32">
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <FontIcon FontSize="16" Glyph="&#xE748;" />
                                        <TextBlock Text="切换账户" />
                                    </StackPanel>
                                    <Button.Flyout>
                                        <Flyout Placement="Bottom">
                                            <StackPanel MinWidth="320" Spacing="8">
                                                <TextBlock
                                                    Margin="8,4,0,4"
                                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                                    Text="当前登录" />
                                                <Grid
                                                    Margin="0,6"
                                                    Padding="8,8"
                                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                    CornerRadius="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <PersonPicture
                                                        Width="32"
                                                        Height="32"
                                                        Margin="0,0,12,0"
                                                        ProfilePicture="{x:Bind ViewModel.CurrentAccount.AvatarUrl, Mode=OneWay}" />
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock
                                                            FontSize="14"
                                                            FontWeight="SemiBold"
                                                            Text="{x:Bind ViewModel.CurrentAccount.Nickname, Mode=OneWay}" />
                                                        <TextBlock
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Text="{x:Bind ViewModel.CurrentAccount.GameUidDisplay, Mode=OneWay}" />
                                                    </StackPanel>
                                                    <TextBlock
                                                        Grid.Column="2"
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                        Text="当前" />
                                                </Grid>

                                                <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.HasSavedAccounts, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock
                                                        Margin="8,8,0,4"
                                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                                        Text="已保存的其他账户" />
                                                    <ListView ItemsSource="{x:Bind ViewModel.SavedAccounts, Mode=OneWay}" SelectionMode="None">
                                                        <ListView.ItemTemplate>
                                                            <DataTemplate x:DataType="models:AccountInfo">
                                                                <Grid Margin="0,4" Padding="0,4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <PersonPicture
                                                                        Width="32"
                                                                        Height="32"
                                                                        Margin="0,0,12,0"
                                                                        ProfilePicture="{x:Bind AvatarUrl}" />
                                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                        <TextBlock
                                                                            FontSize="14"
                                                                            FontWeight="SemiBold"
                                                                            Text="{x:Bind Nickname}" />
                                                                        <TextBlock
                                                                            FontSize="12"
                                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                            Text="{x:Bind GameUidDisplay}" />
                                                                    </StackPanel>
                                                                    <Button
                                                                        Grid.Column="2"
                                                                        Margin="0,0,4,0"
                                                                        Click="OnSwitchAccountClicked"
                                                                        Content="切换"
                                                                        FontSize="12" />
                                                                    <Button
                                                                        Grid.Column="3"
                                                                        Padding="6,4"
                                                                        Background="Transparent"
                                                                        BorderThickness="0"
                                                                        Click="OnDeleteSavedAccountClicked"
                                                                        Tag="{Binding GameUid}">
                                                                        <FontIcon
                                                                            FontSize="12"
                                                                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                                            Glyph="&#xE74D;" />
                                                                    </Button>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ListView.ItemTemplate>
                                                    </ListView>
                                                </StackPanel>
                                                <MenuFlyoutSeparator />
                                                <Button HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.AddAccountCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontSize="12" Glyph="&#xE710;" />
                                                        <TextBlock Text="添加新账户" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>

                                <Button Grid.Row="2"
                                    Command="{x:Bind ViewModel.LoadUserInfoCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Translation="0,0,32">
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <FontIcon FontSize="16" Glyph="&#xE72C;" />
                                        <TextBlock Text="刷新信息" />
                                    </StackPanel>
                                </Button>

                                <Button Grid.Row="4"
                                    Command="{x:Bind ViewModel.OpenGenshinDataCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Translation="0,0,32">
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <FontIcon FontSize="16" Glyph="&#xEB9E;" />
                                        <TextBlock Text="旅行札记" />
                                    </StackPanel>
                                </Button>

                                <Button Grid.Row="6"
                                    Click="OnGachaAnalysisClicked"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Translation="0,0,32">
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <FontIcon FontSize="16" Glyph="&#xE9D2;" />
                                        <TextBlock Text="抽卡分析" />
                                    </StackPanel>
                                </Button>

                                <Button Grid.Row="8"
                                    Command="{x:Bind ViewModel.OpenSecurityCenterCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Translation="0,0,32">
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <FontIcon FontSize="16" Glyph="&#xE72E;" />
                                        <TextBlock Text="账号安全" />
                                    </StackPanel>
                                </Button>

                                <Button Grid.Row="10"
                                    Command="{x:Bind ViewModel.LockAccountCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Translation="0,0,32">
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <FontIcon
                                            FontSize="16"
                                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                            Glyph="&#xE7BA;" />
                                        <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}" Text="冻结账号" />
                                    </StackPanel>
                                </Button>

                                <Button Grid.Row="12"
                                    Command="{x:Bind ViewModel.CopyCookieCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Translation="0,0,32">
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <FontIcon FontSize="16" Glyph="&#xE8C8;" />
                                        <TextBlock Text="复制 Cookie" />
                                    </StackPanel>
                                </Button>

                                <Button Grid.Row="14"
                                    Click="OnDeleteCurrentAccountClicked"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Translation="0,0,32">
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <FontIcon
                                            FontSize="16"
                                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                            Glyph="&#xE74D;" />
                                        <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}" Text="删除账号" />
                                    </StackPanel>
                                </Button>

                                <Button Grid.Row="16"
                                    Command="{x:Bind ViewModel.LogoutCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Translation="0,0,32">
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <FontIcon
                                            FontSize="16"
                                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                            Glyph="&#xE7E8;" />
                                        <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}" Text="退出登录" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>

                        <StackPanel Grid.Column="1" Spacing="24">
                            <Border
                                Style="{StaticResource CardBorderStyle}"
                                Translation="0,0,32"
                                Visibility="{x:Bind ViewModel.UserFullInfo, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <StackPanel Spacing="16">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon
                                            FontSize="16"
                                            Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                            Glyph="&#xE90A;" />
                                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="社区动态" />
                                    </StackPanel>

                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel
                                            Grid.Column="0"
                                            Padding="12"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            CornerRadius="10">
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="获赞数" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="20"
                                                FontWeight="SemiBold">
                                                <Run Text="{x:Bind ViewModel.UserFullInfo.data.user_info.achieve, Mode=OneWay, Converter={StaticResource DictionarySafeConverter}, ConverterParameter=like_num}" />
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="1"
                                            Padding="12"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            CornerRadius="10">
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="发帖数" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="20"
                                                FontWeight="SemiBold">
                                                <Run Text="{x:Bind ViewModel.UserFullInfo.data.user_info.achieve, Mode=OneWay, Converter={StaticResource DictionarySafeConverter}, ConverterParameter=post_num}" />
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="2"
                                            Padding="12"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            CornerRadius="10">
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="回复数" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="20"
                                                FontWeight="SemiBold">
                                                <Run Text="{x:Bind ViewModel.UserFullInfo.data.user_info.achieve, Mode=OneWay, Converter={StaticResource DictionarySafeConverter}, ConverterParameter=replypost_num}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}" Translation="0,0,32">
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <StackPanel Spacing="16">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon
                                            FontSize="16"
                                            Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                            Glyph="&#xE7FC;" />
                                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="绑定角色" />
                                    </StackPanel>

                                    <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.CurrentAccount.HasBoundRole, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.GameRolesInfo.data.list, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border
                                                            Width="40"
                                                            Height="40"
                                                            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                                                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="20">
                                                            <FontIcon
                                                                FontSize="16"
                                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                Glyph="&#xE7F4;" />
                                                        </Border>

                                                        <StackPanel
                                                            Grid.Column="1"
                                                            Margin="12,0,0,0"
                                                            VerticalAlignment="Center">
                                                            <TextBlock FontWeight="Medium" Text="{Binding nickname}" />
                                                            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                                <Run Text="{Binding region_name}" />
                                                                <Run Text=" | Lv." />
                                                                <Run Text="{Binding level}" />
                                                            </TextBlock>
                                                        </StackPanel>

                                                        <TextBlock
                                                            Grid.Column="2"
                                                            Margin="0,0,6,0"
                                                            VerticalAlignment="Center"
                                                            FontFamily="Consolas, Monospace"
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                            Text="{Binding game_uid}" />

                                                        <Button
                                                            Grid.Column="3"
                                                            Width="28"
                                                            Height="28"
                                                            Padding="0"
                                                            VerticalAlignment="Center"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Click="OnCopyGameUidClicked"
                                                            Tag="{Binding game_uid}"
                                                            ToolTipService.ToolTip="复制 UID">
                                                            <FontIcon
                                                                FontSize="12"
                                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                Glyph="&#xE8C8;" />
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <StackPanel
                                        Padding="12"
                                        Orientation="Horizontal"
                                        Spacing="12"
                                        Visibility="{x:Bind ViewModel.CurrentAccount.HasBoundRole, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                        <FontIcon
                                            VerticalAlignment="Center"
                                            FontSize="24"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Glyph="&#xE7F4;" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="14"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="暂无绑定角色" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                Text="请在米游社或游戏中绑定角色后刷新" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}" Translation="0,0,32">
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <StackPanel Spacing="18">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="4">
                                            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="游戏时长" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="近 30 天游玩统计" />
                                        </StackPanel>
                                        <Border
                                            Grid.Column="1"
                                            Padding="8,3"
                                            VerticalAlignment="Top"
                                            Background="{ThemeResource SystemFillColorSuccessBrush}"
                                            CornerRadius="12"
                                            Visibility="{x:Bind ControlPanelViewModel.IsGameRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="游戏中" />
                                        </Border>
                                    </Grid>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Grid.Column="0"
                                            Padding="14"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            CornerRadius="8">
                                            <StackPanel Spacing="4">
                                                <TextBlock
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="总时长" />
                                                <TextBlock
                                                    FontSize="28"
                                                    FontWeight="SemiBold"
                                                    Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                    Text="{x:Bind ControlPanelViewModel.WeeklyStats.TotalHoursFormatted, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                        <Border
                                            Grid.Column="1"
                                            Padding="14"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            CornerRadius="8">
                                            <StackPanel Spacing="4">
                                                <TextBlock
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="日均时长" />
                                                <TextBlock
                                                    FontSize="28"
                                                    FontWeight="SemiBold"
                                                    Text="{x:Bind ControlPanelViewModel.WeeklyStats.AverageHoursFormatted, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid MinHeight="120">
                                        <ScrollViewer
                                            MaxHeight="220"
                                            Padding="0,0,8,0"
                                            VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{x:Bind ControlPanelViewModel.WeeklyStats.DailyRecords, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:GamePlayTimeRecord">
                                                        <Grid
                                                            Margin="0,6"
                                                            Padding="10,8"
                                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                            CornerRadius="6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel
                                                                Grid.Column="0"
                                                                Orientation="Horizontal"
                                                                Spacing="12">
                                                                <TextBlock
                                                                    Width="36"
                                                                    FontSize="13"
                                                                    FontWeight="SemiBold"
                                                                    Text="{x:Bind DayOfWeek}" />
                                                                <TextBlock
                                                                    FontSize="13"
                                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                    Text="{x:Bind DisplayDate}" />
                                                            </StackPanel>
                                                            <TextBlock
                                                                Grid.Column="1"
                                                                FontSize="13"
                                                                FontWeight="SemiBold"
                                                                Text="{x:Bind DisplayTime}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="近 30 天暂无游戏记录"
                                            Visibility="{x:Bind ControlPanelViewModel.WeeklyStats.DailyRecords.Count, Converter={StaticResource EmptyCountToVisibilityConverter}, Mode=OneWay}" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>