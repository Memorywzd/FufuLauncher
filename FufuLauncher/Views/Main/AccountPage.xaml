<Page
    x:Class="FufuLauncher.Views.AccountPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:FufuLauncher.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:FufuLauncher.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FufuLauncher.Models"
    x:Name="RootPage"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <AcrylicBrush
                        x:Key="SafeGlassBrush"
                        FallbackColor="#E5FFFFFF"
                        TintColor="#FFFFFF"
                        TintOpacity="0.6" />
                    <SolidColorBrush x:Key="SafeCardBrush" Color="#0A000000" />
                    <SolidColorBrush x:Key="SafeBorderBrush" Color="#1A000000" />
                    <SolidColorBrush x:Key="SafeHoverBrush" Color="#14000000" />
                    <SolidColorBrush x:Key="SafeTextBrush" Color="#FF000000" />
                    <SolidColorBrush x:Key="SafeSecondaryTextBrush" Color="#99000000" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <AcrylicBrush
                        x:Key="SafeGlassBrush"
                        FallbackColor="#CC000000"
                        TintColor="#000000"
                        TintOpacity="0.15" />
                    <SolidColorBrush x:Key="SafeCardBrush" Color="#14FFFFFF" />
                    <SolidColorBrush x:Key="SafeBorderBrush" Color="#20FFFFFF" />
                    <SolidColorBrush x:Key="SafeHoverBrush" Color="#24FFFFFF" />
                    <SolidColorBrush x:Key="SafeTextBrush" Color="White" />
                    <SolidColorBrush x:Key="SafeSecondaryTextBrush" Color="#B3FFFFFF" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <helpers:NullToOpacityConverter x:Key="NullToOpacityConverter" />
            <helpers:BoolNegationConverter x:Key="BoolNegationConverter" />
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <helpers:DictionarySafeConverter x:Key="DictionarySafeConverter" />
            <converters:EmptyCountToVisibilityConverter x:Key="EmptyCountToVisibilityConverter" />

            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource SafeGlassBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="20" />
            </Style>

            <Style x:Key="ActionButtonStyle" TargetType="Button">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Background" Value="{ThemeResource SafeGlassBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <ContentPresenter
                                    x:Name="ContentPresenter"
                                    Padding="{TemplateBinding Padding}"
                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                    AutomationProperties.AccessibilityView="Raw"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Content="{TemplateBinding Content}"
                                    ContentTransitions="{TemplateBinding ContentTransitions}"
                                    CornerRadius="{TemplateBinding CornerRadius}" />
                                <Border
                                    x:Name="HighlightBorder"
                                    BorderBrush="{ThemeResource TextFillColorPrimaryBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    IsHitTestVisible="False"
                                    Opacity="0" />
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="HighlightBorder"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="0"
                                                    Duration="0:0:0.25" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="HighlightBorder"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="1"
                                                    Duration="0:0:0.25" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed" />
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                               Storyboard.TargetProperty="Foreground">
                                                    <DiscreteObjectKeyFrame KeyTime="0"
                                                                            Value="{ThemeResource TextFillColorTertiaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Storyboard x:Name="EntranceStoryboard">
                <DoubleAnimation
                    Storyboard.TargetName="RootLayoutGrid"
                    Storyboard.TargetProperty="Opacity"
                    From="0"
                    To="1"
                    Duration="0:0:0.6">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    Storyboard.TargetName="RootLayoutTranslate"
                    Storyboard.TargetProperty="Y"
                    From="40"
                    To="0"
                    Duration="0:0:0.6">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
            <Storyboard x:Name="ExitStoryboard">
                <DoubleAnimation
                    Storyboard.TargetName="RootLayoutGrid"
                    Storyboard.TargetProperty="Opacity"
                    From="1"
                    To="0"
                    Duration="0:0:0.3">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseIn" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!--  按钮动画  -->
            <Storyboard x:Name="ButtonsStaggerStoryboard">
                <DoubleAnimation
                    BeginTime="0:0:0"
                    Storyboard.TargetName="BtnSwitchAccountTransform"
                    Storyboard.TargetProperty="Y"
                    From="-80"
                    To="0"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <BackEase Amplitude="0.35" EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0"
                    Storyboard.TargetName="BtnSwitchAccount"
                    Storyboard.TargetProperty="Opacity"
                    From="0"
                    To="1"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.07"
                    Storyboard.TargetName="BtnRefreshInfoTransform"
                    Storyboard.TargetProperty="Y"
                    From="-80"
                    To="0"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <BackEase Amplitude="0.35" EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.07"
                    Storyboard.TargetName="BtnRefreshInfo"
                    Storyboard.TargetProperty="Opacity"
                    From="0"
                    To="1"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.14"
                    Storyboard.TargetName="BtnGenshinDataTransform"
                    Storyboard.TargetProperty="Y"
                    From="-80"
                    To="0"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <BackEase Amplitude="0.35" EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.14"
                    Storyboard.TargetName="BtnGenshinData"
                    Storyboard.TargetProperty="Opacity"
                    From="0"
                    To="1"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.21"
                    Storyboard.TargetName="BtnGachaAnalysisTransform"
                    Storyboard.TargetProperty="Y"
                    From="-80"
                    To="0"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <BackEase Amplitude="0.35" EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.21"
                    Storyboard.TargetName="BtnGachaAnalysis"
                    Storyboard.TargetProperty="Opacity"
                    From="0"
                    To="1"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.28"
                    Storyboard.TargetName="BtnSecurityCenterTransform"
                    Storyboard.TargetProperty="Y"
                    From="-80"
                    To="0"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <BackEase Amplitude="0.35" EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.28"
                    Storyboard.TargetName="BtnSecurityCenter"
                    Storyboard.TargetProperty="Opacity"
                    From="0"
                    To="1"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.35"
                    Storyboard.TargetName="BtnLockAccountTransform"
                    Storyboard.TargetProperty="Y"
                    From="-80"
                    To="0"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <BackEase Amplitude="0.35" EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.35"
                    Storyboard.TargetName="BtnLockAccount"
                    Storyboard.TargetProperty="Opacity"
                    From="0"
                    To="1"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.42"
                    Storyboard.TargetName="BtnCopyCookieTransform"
                    Storyboard.TargetProperty="Y"
                    From="-80"
                    To="0"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <BackEase Amplitude="0.35" EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.42"
                    Storyboard.TargetName="BtnCopyCookie"
                    Storyboard.TargetProperty="Opacity"
                    From="0"
                    To="1"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.49"
                    Storyboard.TargetName="BtnDeleteAccountTransform"
                    Storyboard.TargetProperty="Y"
                    From="-80"
                    To="0"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <BackEase Amplitude="0.35" EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.49"
                    Storyboard.TargetName="BtnDeleteAccount"
                    Storyboard.TargetProperty="Opacity"
                    From="0"
                    To="1"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.56"
                    Storyboard.TargetName="BtnLogoutTransform"
                    Storyboard.TargetProperty="Y"
                    From="-80"
                    To="0"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <BackEase Amplitude="0.35" EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.56"
                    Storyboard.TargetName="BtnLogout"
                    Storyboard.TargetProperty="Opacity"
                    From="0"
                    To="1"
                    Duration="0:0:0.55">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>


            <Storyboard x:Name="RightCardsEntranceStoryboard">
                <DoubleAnimation
                    BeginTime="0:0:0.3"
                    Storyboard.TargetName="CommunityFeedCardTransform"
                    Storyboard.TargetProperty="X"
                    From="50"
                    To="0"
                    Duration="0:0:0.5">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.3"
                    Storyboard.TargetName="CommunityFeedCard"
                    Storyboard.TargetProperty="Opacity"
                    From="0"
                    To="1"
                    Duration="0:0:0.45">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.38"
                    Storyboard.TargetName="BoundRolesCardTransform"
                    Storyboard.TargetProperty="X"
                    From="50"
                    To="0"
                    Duration="0:0:0.5">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.38"
                    Storyboard.TargetName="BoundRolesCard"
                    Storyboard.TargetProperty="Opacity"
                    From="0"
                    To="1"
                    Duration="0:0:0.45">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.46"
                    Storyboard.TargetName="GameTimeCardTransform"
                    Storyboard.TargetProperty="X"
                    From="50"
                    To="0"
                    Duration="0:0:0.5">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    BeginTime="0:0:0.46"
                    Storyboard.TargetName="GameTimeCard"
                    Storyboard.TargetProperty="Opacity"
                    From="0"
                    To="1"
                    Duration="0:0:0.45">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <Storyboard x:Name="ProfileCardEntranceStoryboard">
                <DoubleAnimation
                    Storyboard.TargetName="ProfileCardTransform"
                    Storyboard.TargetProperty="Y"
                    To="0"
                    Duration="0:0:0.5">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    Storyboard.TargetName="ProfileCard"
                    Storyboard.TargetProperty="Opacity"
                    To="1"
                    Duration="0:0:0.45">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </ResourceDictionary>
    </Page.Resources>

    <Grid
        x:Name="RootLayoutGrid"
        Opacity="0"
        RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="RootLayoutScale" ScaleX="1" ScaleY="1" />
                <TranslateTransform x:Name="RootLayoutTranslate" X="0" Y="0" />
            </TransformGroup>
        </Grid.RenderTransform>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,12,24,24" Spacing="24">
                <StackPanel
                    Margin="0,48,0,0"
                    HorizontalAlignment="Center"
                    Spacing="24"
                    Visibility="{x:Bind ViewModel.IsNotLoggedIn, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <FontIcon
                        HorizontalAlignment="Center"
                        FontSize="64"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Glyph="&#xE77B;" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="{helpers:Loc Key=Account_NotLoggedIn}" />
                    <Button
                        Padding="32,12"
                        HorizontalAlignment="Center"
                        Command="{x:Bind ViewModel.LoginCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="16" Glyph="&#xE710;" />
                            <TextBlock Text="{x:Bind ViewModel.LoginButtonText, Mode=OneWay}" />
                        </StackPanel>
                    </Button>

                    <StackPanel
                        Margin="0,32,0,0"
                        Spacing="12"
                        Visibility="{x:Bind ViewModel.HasSavedAccounts, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{helpers:Loc Key=Account_SavedAccounts}" />
                        <ListView
                            Width="320"
                            ItemsSource="{x:Bind ViewModel.SavedAccounts, Mode=OneWay}"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:AccountInfo">
                                    <Grid Margin="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <PersonPicture
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,12,0"
                                            ProfilePicture="{x:Bind AvatarUrl}" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Text="{x:Bind Nickname}" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind GameUid}" />
                                        </StackPanel>
                                        <Button
                                            Grid.Column="2"
                                            Margin="0,0,4,0"
                                            Click="OnSwitchAccountClicked"
                                            Content="{helpers:Loc Key=Account_Login}"
                                            FontSize="12" />
                                        <Button
                                            Grid.Column="3"
                                            Padding="8,4"
                                            Background="Transparent"
                                            Click="OnDeleteSavedAccountClicked"
                                            FontSize="12"
                                            Tag="{Binding GameUid}">
                                            <FontIcon
                                                FontSize="12"
                                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                Glyph="&#xE74D;" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="24"
                            Visibility="{x:Bind ViewModel.IsLoggedIn, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4.5*" />
                            <ColumnDefinition Width="5.5*" />
                        </Grid.ColumnDefinitions>

                        <Grid
                            x:Name="LeftColumnGrid"
                            Grid.Column="0"
                            VerticalAlignment="Top"
                            RowSpacing="24"
                            SizeChanged="LeftColumnGrid_SizeChanged">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border
                                x:Name="ProfileCard"
                                Style="{StaticResource CardBorderStyle}"
                                Translation="0,0,32">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ProfileCardTransform" Y="0" />
                                </Border.RenderTransform>
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Ellipse
                                        x:Name="AvatarPicture"
                                        Width="84"
                                        Height="84">
                                        <Ellipse.Fill>
                                            <ImageBrush
                                                ImageSource="{x:Bind ViewModel.CurrentAccount.AvatarUrl, Mode=OneWay}"
                                                Stretch="UniformToFill" />
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="6">
                                        <StackPanel
                                            VerticalAlignment="Bottom"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Style="{StaticResource SubtitleTextBlockStyle}"
                                                Text="{x:Bind ViewModel.CurrentAccount.Nickname, Mode=OneWay}" />

                                            <Border
                                                Padding="8,2"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                                <StackPanel
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal"
                                                    Spacing="4">
                                                    <FontIcon
                                                        FontFamily="Segoe Fluent Icons"
                                                        FontSize="12"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Glyph="{x:Bind ViewModel.CurrentAccount.GenderIcon, Mode=OneWay}" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Text="{x:Bind ViewModel.CurrentAccount.GenderText, Mode=OneWay}" />
                                                </StackPanel>
                                            </Border>

                                            <Border
                                                Margin="4,0,0,0"
                                                Padding="6,2"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="10">
                                                <TextBlock
                                                    FontSize="10"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    Text="{x:Bind ViewModel.CurrentAccount.LevelDisplay, Mode=OneWay}" />
                                            </Border>
                                        </StackPanel>

                                        <TextBlock
                                            FontSize="13"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            MaxLines="1"
                                            Text="{x:Bind ViewModel.CurrentAccount.Sign, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />

                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                                <Run Text="UID:" />
                                                <Run FontWeight="SemiBold"
                                                     Text="{x:Bind ViewModel.CurrentAccount.GameUidDisplay, Mode=OneWay}" />
                                            </TextBlock>

                                            <Border
                                                Width="1"
                                                Height="10"
                                                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                Text="{x:Bind ViewModel.CurrentAccount.Server, Mode=OneWay}" />

                                            <Border
                                                Width="1"
                                                Height="10"
                                                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                                            <StackPanel
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal"
                                                Spacing="4">
                                                <FontIcon
                                                    FontFamily="Segoe Fluent Icons"
                                                    FontSize="10"
                                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                    Glyph="&#xE81D;" />
                                                <TextBlock
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                    Text="{x:Bind ViewModel.CurrentAccount.IpRegion, Mode=OneWay}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                        <ProgressRing
                                            Width="20"
                                            Height="20"
                                            IsActive="{x:Bind ViewModel.IsLoadingUserInfo, Mode=OneWay}"
                                            Visibility="{x:Bind ViewModel.IsLoadingUserInfo, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid x:Name="BtnGrid" Grid.Row="1" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Button
                                    x:Name="BtnSwitchAccount"
                                    Grid.Row="0"
                                    Click="OnCheckinClicked"
                                    Opacity="0"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Translation="0,0,32">
                                    <Button.RenderTransform>
                                        <TranslateTransform x:Name="BtnSwitchAccountTransform" Y="-80" />
                                    </Button.RenderTransform>
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <Grid Background="Transparent">
                                        <Canvas IsHitTestVisible="False" />
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <FontIcon FontSize="16" Glyph="&#xE916;" />
                                            <TextBlock x:Name="BtnCheckinText" Text="{helpers:Loc Key=Account_DailyCheckin}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button
                                    x:Name="BtnRefreshInfo"
                                    Grid.Row="1"
                                    Command="{x:Bind ViewModel.LoadUserInfoCommand}"
                                    Opacity="0"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Translation="0,0,32">
                                    <Button.RenderTransform>
                                        <TranslateTransform x:Name="BtnRefreshInfoTransform" Y="-80" />
                                    </Button.RenderTransform>
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <Grid Background="Transparent">
                                        <Canvas IsHitTestVisible="False" />
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <FontIcon FontSize="16" Glyph="&#xE72C;" />
                                            <TextBlock Text="{helpers:Loc Key=Account_RefreshInfo}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button
                                    x:Name="BtnGenshinData"
                                    Grid.Row="2"
                                    Command="{x:Bind ViewModel.OpenGenshinDataCommand}"
                                    Opacity="0"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Translation="0,0,32">
                                    <Button.RenderTransform>
                                        <TranslateTransform x:Name="BtnGenshinDataTransform" Y="-80" />
                                    </Button.RenderTransform>
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <Grid Background="Transparent">
                                        <Canvas IsHitTestVisible="False" />
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <FontIcon FontSize="16" Glyph="&#xEB9E;" />
                                            <TextBlock Text="{helpers:Loc Key=Account_TravelJournal}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button
                                    x:Name="BtnGachaAnalysis"
                                    Grid.Row="3"
                                    Click="OnGachaAnalysisClicked"
                                    Opacity="0"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Translation="0,0,32">
                                    <Button.RenderTransform>
                                        <TranslateTransform x:Name="BtnGachaAnalysisTransform" Y="-80" />
                                    </Button.RenderTransform>
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <Grid Background="Transparent">
                                        <Canvas IsHitTestVisible="False" />
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <FontIcon FontSize="16" Glyph="&#xE9D2;" />
                                            <TextBlock Text="{helpers:Loc Key=Account_GachaAnalysis}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button
                                    x:Name="BtnSecurityCenter"
                                    Grid.Row="4"
                                    Command="{x:Bind ViewModel.OpenSecurityCenterCommand}"
                                    Opacity="0"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Translation="0,0,32">
                                    <Button.RenderTransform>
                                        <TranslateTransform x:Name="BtnSecurityCenterTransform" Y="-80" />
                                    </Button.RenderTransform>
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <Grid Background="Transparent">
                                        <Canvas IsHitTestVisible="False" />
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <FontIcon FontSize="16" Glyph="&#xE72E;" />
                                            <TextBlock Text="{helpers:Loc Key=Account_AccountSecurity}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button
                                    x:Name="BtnLockAccount"
                                    Grid.Row="5"
                                    Command="{x:Bind ViewModel.LockAccountCommand}"
                                    Opacity="0"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Translation="0,0,32">
                                    <Button.RenderTransform>
                                        <TranslateTransform x:Name="BtnLockAccountTransform" Y="-80" />
                                    </Button.RenderTransform>
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <Grid Background="Transparent">
                                        <Canvas IsHitTestVisible="False" />
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <FontIcon
                                                FontSize="16"
                                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                Glyph="&#xE7BA;" />
                                            <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                       Text="{helpers:Loc Key=Account_FreezeAccount}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button
                                    x:Name="BtnCopyCookie"
                                    Grid.Row="6"
                                    Command="{x:Bind ViewModel.CopyCookieCommand}"
                                    Opacity="0"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Translation="0,0,32">
                                    <Button.RenderTransform>
                                        <TranslateTransform x:Name="BtnCopyCookieTransform" Y="-80" />
                                    </Button.RenderTransform>
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <Grid Background="Transparent">
                                        <Canvas IsHitTestVisible="False" />
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <FontIcon FontSize="16" Glyph="&#xE8C8;" />
                                            <TextBlock Text="{helpers:Loc Key=Account_CopyCookie}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button
                                    x:Name="BtnDeleteAccount"
                                    Grid.Row="7"
                                    Click="OnDeleteCurrentAccountClicked"
                                    Opacity="0"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Translation="0,0,32">
                                    <Button.RenderTransform>
                                        <TranslateTransform x:Name="BtnDeleteAccountTransform" Y="-80" />
                                    </Button.RenderTransform>
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <Grid Background="Transparent">
                                        <Canvas IsHitTestVisible="False" />
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <FontIcon
                                                FontSize="16"
                                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                Glyph="&#xE74D;" />
                                            <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                       Text="{helpers:Loc Key=Account_DeleteAccount}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button
                                    x:Name="BtnLogout"
                                    Grid.Row="8"
                                    Command="{x:Bind ViewModel.LogoutCommand}"
                                    Opacity="0"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Translation="0,0,32">
                                    <Button.RenderTransform>
                                        <TranslateTransform x:Name="BtnLogoutTransform" Y="-80" />
                                    </Button.RenderTransform>
                                    <Button.Shadow>
                                        <ThemeShadow />
                                    </Button.Shadow>
                                    <Grid Background="Transparent">
                                        <Canvas IsHitTestVisible="False" />
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <FontIcon
                                                FontSize="16"
                                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                Glyph="&#xE7E8;" />
                                            <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                       Text="{helpers:Loc Key=Account_Logout}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </Grid>
                        </Grid>

                        <Grid
                            x:Name="RightGrid"
                            Grid.Column="1"
                            RowSpacing="24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" MaxHeight="240" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border
                                x:Name="CommunityFeedCard"
                                Grid.Row="0"
                                Opacity="0"
                                Style="{StaticResource CardBorderStyle}"
                                Translation="0,0,32">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="CommunityFeedCardTransform" X="50" />
                                </Border.RenderTransform>
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <StackPanel Spacing="16">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon
                                            FontSize="16"
                                            Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                            Glyph="&#xE90A;" />
                                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{helpers:Loc Key=Account_CommunityFeed}" />
                                    </StackPanel>

                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel
                                            Grid.Column="0"
                                            Padding="12"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            CornerRadius="10">
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{helpers:Loc Key=Account_Likes}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="20"
                                                FontWeight="SemiBold"
                                                Text="{x:Bind ViewModel.CommunityLikeCount, Mode=OneWay}" />
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="1"
                                            Padding="12"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            CornerRadius="10">
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{helpers:Loc Key=Account_Posts}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="20"
                                                FontWeight="SemiBold"
                                                Text="{x:Bind ViewModel.CommunityPostCount, Mode=OneWay}" />
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="2"
                                            Padding="12"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            CornerRadius="10">
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{helpers:Loc Key=Account_Replies}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="20"
                                                FontWeight="SemiBold"
                                                Text="{x:Bind ViewModel.CommunityReplyCount, Mode=OneWay}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border
                                x:Name="BoundRolesCard"
                                Grid.Row="1"
                                Opacity="0"
                                Style="{StaticResource CardBorderStyle}"
                                Translation="0,0,32">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="BoundRolesCardTransform" X="50" />
                                </Border.RenderTransform>
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <Grid RowSpacing="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel
                                        Grid.Row="0"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <FontIcon
                                            FontSize="16"
                                            Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                            Glyph="&#xE7FC;" />
                                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{helpers:Loc Key=Account_BoundCharacters}" />
                                    </StackPanel>

                                    <ScrollViewer
                                        Grid.Row="1"
                                        VerticalScrollBarVisibility="Auto"
                                        Visibility="{x:Bind ViewModel.CurrentAccount.HasBoundRole, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.BoundRoles, Mode=OneWay}">

                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border
                                                            Width="40"
                                                            Height="40"
                                                            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                                                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="20">
                                                            <FontIcon
                                                                FontSize="16"
                                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                Glyph="&#xE7F4;" />
                                                        </Border>

                                                        <StackPanel
                                                            Grid.Column="1"
                                                            Margin="12,0,0,0"
                                                            VerticalAlignment="Center">
                                                            <TextBlock FontWeight="Medium" Text="{Binding nickname}" />
                                                            <TextBlock FontSize="12"
                                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                                <Run Text="{Binding region_name}" />
                                                                <Run Text=" | Lv." />
                                                                <Run Text="{Binding level}" />
                                                            </TextBlock>
                                                        </StackPanel>

                                                        <TextBlock
                                                            Grid.Column="2"
                                                            Margin="0,0,6,0"
                                                            VerticalAlignment="Center"
                                                            FontFamily="Consolas, Monospace"
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                            Text="{Binding game_uid}" />

                                                        <Button
                                                            Grid.Column="3"
                                                            Width="28"
                                                            Height="28"
                                                            Padding="0"
                                                            VerticalAlignment="Center"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Click="OnCopyGameUidClicked"
                                                            Tag="{Binding game_uid}"
                                                            ToolTipService.ToolTip="{helpers:Loc Key=Account_CopyUID}">
                                                            <FontIcon
                                                                FontSize="12"
                                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                Glyph="&#xE8C8;" />
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <StackPanel
                                        Grid.Row="1"
                                        Padding="12"
                                        Orientation="Horizontal"
                                        Spacing="12"
                                        Visibility="{x:Bind ViewModel.CurrentAccount.HasBoundRole, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                        <FontIcon
                                            VerticalAlignment="Center"
                                            FontSize="24"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Glyph="&#xE7F4;" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="14"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{helpers:Loc Key=Account_NoCharacters}" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                Text="{helpers:Loc Key=Account_BindHint}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border
                                x:Name="GameTimeCard"
                                Grid.Row="2"
                                Opacity="0"
                                Style="{StaticResource CardBorderStyle}"
                                Translation="0,0,32">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="GameTimeCardTransform" X="50" />
                                </Border.RenderTransform>
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <Grid RowSpacing="18">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="4">
                                            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{helpers:Loc Key=Account_PlayTime}" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{helpers:Loc Key=Account_RecentDays30}" />
                                        </StackPanel>
                                        <Border
                                            Grid.Column="1"
                                            Padding="8,3"
                                            VerticalAlignment="Top"
                                            Background="{ThemeResource SystemFillColorSuccessBrush}"
                                            CornerRadius="12"
                                            Visibility="{x:Bind ControlPanelViewModel.IsGameRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{helpers:Loc Key=Account_InGame}" />
                                        </Border>
                                    </Grid>
                                    <Grid Grid.Row="1" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Grid.Column="0"
                                            Padding="14"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            CornerRadius="8">
                                            <StackPanel Spacing="4">
                                                <TextBlock
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{helpers:Loc Key=Account_TotalTime}" />
                                                <TextBlock
                                                    FontSize="28"
                                                    FontWeight="SemiBold"
                                                    Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                    Text="{x:Bind ControlPanelViewModel.WeeklyStats.TotalHoursFormatted, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                        <Border
                                            Grid.Column="1"
                                            Padding="14"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            CornerRadius="8">
                                            <StackPanel Spacing="4">
                                                <TextBlock
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{helpers:Loc Key=Account_DailyAvg}" />
                                                <TextBlock
                                                    FontSize="28"
                                                    FontWeight="SemiBold"
                                                    Text="{x:Bind ControlPanelViewModel.WeeklyStats.AverageHoursFormatted, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid Grid.Row="2">
                                        <ScrollViewer Padding="0,0,8,0" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl
                                                ItemsSource="{x:Bind ControlPanelViewModel.WeeklyStats.DailyRecords, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:GamePlayTimeRecord">
                                                        <Grid
                                                            Margin="0,6"
                                                            Padding="10,8"
                                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                            CornerRadius="6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel
                                                                Grid.Column="0"
                                                                Orientation="Horizontal"
                                                                Spacing="12">
                                                                <TextBlock
                                                                    Width="36"
                                                                    FontSize="13"
                                                                    FontWeight="SemiBold"
                                                                    Text="{x:Bind DayOfWeek}" />
                                                                <TextBlock
                                                                    FontSize="13"
                                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                    Text="{x:Bind DisplayDate}" />
                                                            </StackPanel>
                                                            <TextBlock
                                                                Grid.Column="1"
                                                                FontSize="13"
                                                                FontWeight="SemiBold"
                                                                Text="{x:Bind DisplayTime}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{helpers:Loc Key=Account_NoRecentRecords30}"
                                            Visibility="{x:Bind ControlPanelViewModel.WeeklyStats.DailyRecords.Count, Converter={StaticResource EmptyCountToVisibilityConverter}, Mode=OneWay}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>