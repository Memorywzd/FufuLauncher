<Page
    x:Class="FufuLauncher.Views.HelpPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:models="using:FufuLauncher.Models"
    Background="Transparent">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBox x:Name="SearchBox" 
                     PlaceholderText="搜索标题、文件名或内容..." 
                     TextChanged="SearchBox_TextChanged" 
                     Margin="16,16,16,8">
                <FlyoutBase.AttachedFlyout>
                    <Flyout x:Name="DocSearchResultsFlyout"
                            Placement="BottomEdgeAlignedLeft"
                            ShouldConstrainToRootBounds="True">
                        <Flyout.FlyoutPresenterStyle>
                            <Style TargetType="FlyoutPresenter">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled" />
                                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
                            </Style>
                        </Flyout.FlyoutPresenterStyle>
                        <Border MaxWidth="560"
                                Padding="0,4,0,8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="SearchFlyoutSummary"
                                           Grid.Row="0"
                                           Margin="16,8,16,4"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <ListView x:Name="SearchHitsList"
                                          Grid.Row="1"
                                          MaxHeight="380"
                                          Padding="4,0,4,8"
                                          IsItemClickEnabled="True"
                                          ItemClick="SearchHitsList_ItemClick"
                                          SelectionMode="None"
                                          ScrollViewer.HorizontalScrollMode="Disabled"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          ItemsSource="{x:Bind ViewModel.SearchHits, Mode=OneWay}">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:DocSearchHit">
                                            <StackPanel Padding="12,10" Spacing="4">
                                                <TextBlock Text="{x:Bind Title}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{x:Bind Subtitle}"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{x:Bind Preview}"
                                                           FontSize="12"
                                                           Opacity="0.92"
                                                           TextWrapping="Wrap"
                                                           MaxLines="4"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>
                    </Flyout>
                </FlyoutBase.AttachedFlyout>
            </TextBox>

            <TreeView x:Name="DirectoryTreeView" 
                      Grid.Row="1"
                      SelectionMode="Single"
                      ItemInvoked="DirectoryTreeView_ItemInvoked"
                      CanReorderItems="False"
                      CanDragItems="False">
                <TreeView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Margin="0,6,0,6" />
                    </DataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
            
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" 
                          Grid.Row="1"
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"/>
        </Grid>

        <ScrollViewer Grid.Column="1"
                      HorizontalScrollMode="Disabled"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <Grid Padding="40,32,40,40" MaxWidth="1200" HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{x:Bind ViewModel.CurrentTitle, Mode=OneWay}" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           TextWrapping="Wrap" 
                           Margin="0,0,0,12"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16" Margin="0,0,0,24" Opacity="0.6">
                    <TextBlock Text="{x:Bind ViewModel.CurrentAuthor, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind ViewModel.CurrentDate, Mode=OneWay}" />
                </StackPanel>

                <controls:MarkdownTextBlock x:Name="HelpMarkdown"
                    Grid.Row="2"
                    Text="{x:Bind ViewModel.MarkdownContent, Mode=OneWay}"
                    UriPrefix="{x:Bind ViewModel.MarkdownUriPrefix, Mode=OneWay}"
                    FontSize="14"
                    Background="Transparent"
                    TextWrapping="Wrap"
                    HorizontalAlignment="Stretch"
                    IsTextSelectionEnabled="False"
                    UseSyntaxHighlighting="True"
                    WrapCodeBlock="True"
                    ImageStretch="Uniform"
                    ImageMaxWidth="800"
                    ImageMaxHeight="1600"
                    SizeChanged="HelpMarkdown_SizeChanged"
                    LinkClicked="HelpMarkdown_LinkClicked"
                    
                    CodeBackground="{ThemeResource ControlFillColorDefaultBrush}"
                    CodeBorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    CodeBorderThickness="1"
                    CodePadding="16"
                    CodeMargin="0,12,0,12"
                    CodeForeground="{ThemeResource TextFillColorPrimaryBrush}"
                    CodeFontFamily="Consolas, Courier New, monospace"
                    
                    InlineCodeBackground="{ThemeResource ControlFillColorDefaultBrush}"
                    InlineCodeBorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    InlineCodeBorderThickness="1"
                    InlineCodePadding="6,2,6,2"
                    InlineCodeFontFamily="Consolas, Courier New, monospace"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>