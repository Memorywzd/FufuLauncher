<Page x:Class="FufuLauncher.Views.SettingsPage"
      x:Name="SettingsPageRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="using:FufuLauncher.Helpers"
      xmlns:models="using:FufuLauncher.Models"
      xmlns:viewModels="using:FufuLauncher.ViewModels"
      xmlns:converters="using:FufuLauncher.Converters"
      Background="Transparent"
      Loaded="Page_Loaded">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <AcrylicBrush x:Key="SafeGlassBrush" FallbackColor="#E5FFFFFF" TintColor="#FFFFFF"
                                  TintOpacity="0.6" />
                    <SolidColorBrush x:Key="SafeCardBrush" Color="#0A000000" />
                    <SolidColorBrush x:Key="SafeBorderBrush" Color="#1A000000" />
                    <SolidColorBrush x:Key="SafeTextBrush" Color="#FF000000" />
                    <SolidColorBrush x:Key="SafeSecondaryTextBrush" Color="#99000000" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <AcrylicBrush x:Key="SafeGlassBrush" FallbackColor="#CC000000" TintColor="#000000"
                                  TintOpacity="0.15" />
                    <SolidColorBrush x:Key="SafeCardBrush" Color="#14FFFFFF" />
                    <SolidColorBrush x:Key="SafeBorderBrush" Color="#20FFFFFF" />
                    <SolidColorBrush x:Key="SafeTextBrush" Color="White" />
                    <SolidColorBrush x:Key="SafeSecondaryTextBrush" Color="#B3FFFFFF" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
            <helpers:EnumToIntConverter x:Key="EnumToIntConverter" />
            <helpers:LanguageEnumToBooleanConverter x:Key="LanguageEnumToBooleanConverter" />
            <helpers:WindowModeEnumToBooleanConverter x:Key="WindowModeEnumToBooleanConverter" />
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <helpers:StringFormatConverter x:Key="StringFormatConverter" />
            <converters:BoolInverter x:Key="BoolInverter" />

            <Storyboard x:Name="EntranceStoryboard">
                <DoubleAnimation Storyboard.TargetName="RootLayoutGrid"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="0:0:0.6">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
            <Storyboard x:Name="ExitStoryboard">
                <DoubleAnimation Storyboard.TargetName="RootLayoutGrid"
                                 Storyboard.TargetProperty="Opacity"
                                 From="1" To="0" Duration="0:0:0.3">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseIn" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <Style x:Key="PresetButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource SafeCardBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource SafeTextBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="14,6" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Height" Value="32" />
                <Setter Property="CornerRadius" Value="10" />
            </Style>

            <Style x:Key="SettingsCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource SafeGlassBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="28,24,28,24" />
                <Setter Property="Margin" Value="0,0,0,18" />
            </Style>

            <Style x:Key="SettingItemStyle" TargetType="StackPanel">
                <Setter Property="Spacing" Value="8" />
                <Setter Property="Margin" Value="0,12,0,0" />
            </Style>

            <Style x:Key="SectionTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource SubtitleTextBlockStyle}">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="SectionAccentBarStyle" TargetType="Border">
                <Setter Property="Width" Value="4" />
                <Setter Property="Height" Value="22" />
                <Setter Property="CornerRadius" Value="2" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Background" Value="{ThemeResource AccentFillColorDefaultBrush}" />
            </Style>

            <Style x:Key="SectionHeaderPanelStyle" TargetType="StackPanel">
                <Setter Property="Orientation" Value="Horizontal" />
                <Setter Property="Spacing" Value="12" />
                <Setter Property="Margin" Value="0,0,0,20" />
            </Style>

            <Style x:Key="SettingLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStrongTextBlockStyle}">
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style x:Key="SettingCaptionStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
                <Setter Property="Opacity" Value="0.7" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="SettingDividerStyle" TargetType="Border">
                <Setter Property="Height" Value="1" />
                <Setter Property="Margin" Value="0,20,0,4" />
                <Setter Property="Background" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="Opacity" Value="0.6" />
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid x:Name="RootLayoutGrid" Opacity="0" RenderTransformOrigin="0.5,0.5">
        <Grid.Transitions>
            <TransitionCollection>
                <EntranceThemeTransition FromVerticalOffset="40" />
            </TransitionCollection>
        </Grid.Transitions>
        <Grid.RenderTransform>
            <ScaleTransform x:Name="RootLayoutScale" ScaleX="1" ScaleY="1" />
        </Grid.RenderTransform>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <NavigationView x:Name="SettingsNavigationView"
                        Grid.Column="0"
                        PaneDisplayMode="Left"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        IsPaneOpen="True"
                        SelectionChanged="SettingsNavigationView_SelectionChanged"
                        Margin="0,0,0,0"
                        Width="220">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="{helpers:Loc Key=SectionAppearance}" Tag="AppearanceItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE771;" FontFamily="Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{helpers:Loc Key=SectionHomeText}" Tag="HomeTextItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE790;" FontFamily="Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{helpers:Loc Key=SectionLanguage}" Tag="LanguageItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF2B7;" FontFamily="Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{helpers:Loc Key=SectionLaunchConfig}" Tag="LaunchConfigItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7FC;" FontFamily="Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{helpers:Loc Key=SectionBackground}" Tag="BackgroundItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE771;" FontFamily="Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{helpers:Loc Key=SectionWindowEffects}" Tag="WindowEffectsItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B3;" FontFamily="Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{helpers:Loc Key=SectionStartupSound}" Tag="StartupSoundItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8D6;" FontFamily="Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{helpers:Loc Key=SectionCheckinSettings}" Tag="CheckinSettingsItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE73E;" FontFamily="Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{helpers:Loc Key=SectionAdvancedOptions}" Tag="AdvancedOptionsItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" FontFamily="Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{helpers:Loc Key=SectionScreenshotSettings}" Tag="ScreenshotSettingsItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE722;" FontFamily="Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{helpers:Loc Key=SectionUpdate}" Tag="UpdateItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE895;" FontFamily="Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{helpers:Loc Key=SectionAbout}" Tag="AboutItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE897;" FontFamily="Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{helpers:Loc Key=SectionSecurityAuth}" Tag="SecurityAuthItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE72E;" FontFamily="Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
        </NavigationView>

        <ScrollViewer x:Name="SettingsScrollViewer"
                      Grid.Column="1"
                      Padding="20,4,20,16"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Disabled"
                      ViewChanged="SettingsScrollViewer_ViewChanged">
            <StackPanel Spacing="0" MaxWidth="860" HorizontalAlignment="Stretch">

                <Border x:Name="AppearanceItem" Style="{StaticResource SettingsCardStyle}" Translation="0,0,32">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderPanelStyle}">
                            <Border Style="{StaticResource SectionAccentBarStyle}" />
                            <TextBlock Text="{helpers:Loc Key=SectionAppearance}" Style="{StaticResource SectionTitleStyle}" />
                        </StackPanel>

                        <TextBlock Text="{helpers:Loc Key=ThemeTitle}"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   FontSize="14" />
                        <TextBlock Text="{helpers:Loc Key=ThemeCaption}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,2,0,12" />

                        <StackPanel Style="{StaticResource SettingItemStyle}">
                            <RadioButton Content="{helpers:Loc Key=ThemeLight}"
                                         FontSize="14"
                                         GroupName="AppTheme"
                                         Command="{x:Bind ViewModel.SwitchThemeCommand}"
                                         IsChecked="{x:Bind ViewModel.ElementTheme, Mode=OneWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Light}">
                                <RadioButton.CommandParameter>
                                    <ElementTheme>Light</ElementTheme>
                                </RadioButton.CommandParameter>
                            </RadioButton>
                            <RadioButton Content="{helpers:Loc Key=ThemeDark}"
                                         FontSize="14"
                                         GroupName="AppTheme"
                                         Command="{x:Bind ViewModel.SwitchThemeCommand}"
                                         IsChecked="{x:Bind ViewModel.ElementTheme, Mode=OneWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Dark}">
                                <RadioButton.CommandParameter>
                                    <ElementTheme>Dark</ElementTheme>
                                </RadioButton.CommandParameter>
                            </RadioButton>
                            <RadioButton Content="{helpers:Loc Key=ThemeSystem}"
                                         FontSize="14"
                                         GroupName="AppTheme"
                                         Command="{x:Bind ViewModel.SwitchThemeCommand}"
                                         IsChecked="{x:Bind ViewModel.ElementTheme, Mode=OneWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Default}">
                                <RadioButton.CommandParameter>
                                    <ElementTheme>Default</ElementTheme>
                                </RadioButton.CommandParameter>
                            </RadioButton>
                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="{helpers:Loc Key=CustomThemeColorTitle}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14" />
                            <TextBlock Text="{helpers:Loc Key=CustomThemeColorCaption}"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.7"
                                       Margin="0,2,0,8" />

                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <TextBox Text="{x:Bind ViewModel.AppThemeColor, Mode=TwoWay}"
                                         PlaceholderText="#FFB6C1"
                                         Width="150"
                                         VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="{helpers:Loc Key=HomeCardDisplayTitle}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14" />
                            <TextBlock Text="{helpers:Loc Key=HomeCardDisplayCaption}"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.7"
                                       Margin="0,2,0,12" />

                            <ToggleSwitch Header="{helpers:Loc Key=HideGameNewsCard}"
                                          OffContent="{helpers:Loc Key=Show}"
                                          OnContent="{helpers:Loc Key=Hide}"
                                          IsOn="{x:Bind ViewModel.IsHideGameNewsCardEnabled, Mode=TwoWay}" />

                            <ToggleSwitch Header="{helpers:Loc Key=HideCheckinCard}"
                                          OffContent="{helpers:Loc Key=Show}"
                                          OnContent="{helpers:Loc Key=Hide}"
                                          IsOn="{x:Bind ViewModel.IsHideCheckinCardEnabled, Mode=TwoWay}" />

                            <ToggleSwitch Header="{helpers:Loc Key=ShowPresetCard}"
                                          OffContent="{helpers:Loc Key=Hide}"
                                          OnContent="{helpers:Loc Key=Show}"
                                          IsOn="{x:Bind ViewModel.IsShowPresetCardEnabled, Mode=TwoWay}" />

                            <ToggleSwitch Header="{helpers:Loc Key=ShowWidgetCard}"
                                          OffContent="{helpers:Loc Key=Hide}"
                                          OnContent="{helpers:Loc Key=Show}"
                                          IsOn="{x:Bind ViewModel.IsShowWidgetCardEnabled, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="{helpers:Loc Key=WidgetItemsTitle}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14" />
                            <TextBlock Text="{helpers:Loc Key=WidgetItemsCaption}"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.7"
                                       Margin="0,2,0,12" />

                            <ToggleSwitch Header="{helpers:Loc Key=WidgetGacha}" OffContent="{helpers:Loc Key=Hide}" OnContent="{helpers:Loc Key=Show}"
                                          IsOn="{x:Bind ViewModel.ShowWidgetGacha, Mode=TwoWay}" />
                            <ToggleSwitch Header="{helpers:Loc Key=WidgetAchievement}" OffContent="{helpers:Loc Key=Hide}" OnContent="{helpers:Loc Key=Show}"
                                          IsOn="{x:Bind ViewModel.ShowWidgetAchievement, Mode=TwoWay}" />
                            <ToggleSwitch Header="{helpers:Loc Key=WidgetInventory}" OffContent="{helpers:Loc Key=Hide}" OnContent="{helpers:Loc Key=Show}"
                                          IsOn="{x:Bind ViewModel.ShowWidgetInventory, Mode=TwoWay}" />
                            <ToggleSwitch Header="{helpers:Loc Key=WidgetPlayerRole}" OffContent="{helpers:Loc Key=Hide}" OnContent="{helpers:Loc Key=Show}"
                                          IsOn="{x:Bind ViewModel.ShowWidgetPlayerRole, Mode=TwoWay}" />
                            <ToggleSwitch Header="{helpers:Loc Key=WidgetDailyNoteWindow}" OffContent="{helpers:Loc Key=Hide}" OnContent="{helpers:Loc Key=Show}"
                                          IsOn="{x:Bind ViewModel.ShowWidgetDailyNoteWindow, Mode=TwoWay}" />
                            <ToggleSwitch Header="{helpers:Loc Key=WidgetVideo}" OffContent="{helpers:Loc Key=Hide}" OnContent="{helpers:Loc Key=Show}"
                                          IsOn="{x:Bind ViewModel.ShowWidgetVideo, Mode=TwoWay}" />
                            <ToggleSwitch Header="{helpers:Loc Key=WidgetBBS}" OffContent="{helpers:Loc Key=Hide}" OnContent="{helpers:Loc Key=Show}"
                                          IsOn="{x:Bind ViewModel.ShowWidgetBBS, Mode=TwoWay}" />
                        </StackPanel>

                        <TextBlock Text="{helpers:Loc Key=LaunchButtonBgColorTitle}"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   FontSize="14" />
                        <StackPanel Style="{StaticResource SettingItemStyle}" Orientation="Horizontal" Spacing="12"
                                    Margin="0,8,0,24">
                            <TextBox Header="{helpers:Loc Key=ColorHex}" Width="150"
                                     Text="{x:Bind ViewModel.LaunchButtonOverlayColor, Mode=TwoWay}"
                                     PlaceholderText="#0078D7" />
                            <Button Content="{helpers:Loc Key=RestoreDefault}"
                                    Command="{x:Bind ViewModel.ResetLaunchButtonOverlayColorCommand}"
                                    Style="{StaticResource PresetButtonStyle}"
                                    VerticalAlignment="Bottom" />
                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="{helpers:Loc Key=NotesItemsTitle}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14" />
                            <TextBlock Text="{helpers:Loc Key=NotesItemsCaption}"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.7"
                                       Margin="0,2,0,8" />

                            <InfoBar Severity="Warning"
                                     Title="{helpers:Loc Key=NotesWarningTitle}"
                                     Message="{helpers:Loc Key=NotesWarningMessage}"
                                     IsOpen="True"
                                     IsClosable="False"
                                     Margin="0,0,0,8" />

                            <ToggleSwitch Header="{helpers:Loc Key=HideNotesCard}"
                                          OffContent="{helpers:Loc Key=Show}"
                                          OnContent="{helpers:Loc Key=Hide}"
                                          IsOn="{x:Bind ViewModel.IsHideDailyNoteCardEnabled, Mode=TwoWay}" />

                            <ToggleSwitch Header="{helpers:Loc Key=ShowResin}"
                                          OffContent="{helpers:Loc Key=Hide}"
                                          OnContent="{helpers:Loc Key=Show}"
                                          IsOn="{x:Bind ViewModel.ShowDailyNoteResin, Mode=TwoWay}" />

                            <ToggleSwitch Header="{helpers:Loc Key=ShowDailyTasks}"
                                          OffContent="{helpers:Loc Key=Hide}"
                                          OnContent="{helpers:Loc Key=Show}"
                                          IsOn="{x:Bind ViewModel.ShowDailyNoteDailyTasks, Mode=TwoWay}" />

                            <ToggleSwitch Header="{helpers:Loc Key=ShowHomeCoin}"
                                          OffContent="{helpers:Loc Key=Hide}"
                                          OnContent="{helpers:Loc Key=Show}"
                                          IsOn="{x:Bind ViewModel.ShowDailyNoteHomeCoin, Mode=TwoWay}" />

                            <ToggleSwitch Header="{helpers:Loc Key=ShowExpeditions}"
                                          OffContent="{helpers:Loc Key=Hide}"
                                          OnContent="{helpers:Loc Key=Show}"
                                          IsOn="{x:Bind ViewModel.ShowDailyNoteExpeditions, Mode=TwoWay}" />

                            <ToggleSwitch Header="{helpers:Loc Key=ShowTransformer}"
                                          OffContent="{helpers:Loc Key=Hide}"
                                          OnContent="{helpers:Loc Key=Show}"
                                          IsOn="{x:Bind ViewModel.ShowDailyNoteTransformer, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="{helpers:Loc Key=NavItemsTitle}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14" />
                            <TextBlock Text="{helpers:Loc Key=NavItemsCaption}"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.7"
                                       Margin="0,2,0,12" />

                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.NavItems}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:NavItemConfig">
                                        <ToggleSwitch Header="{x:Bind DisplayName}"
                                                      IsOn="{x:Bind IsUserVisible, Mode=TwoWay}"
                                                      IsEnabled="{x:Bind IsForceVisible, Converter={StaticResource BoolInverter}}"
                                                      OffContent="{helpers:Loc Key=Hide}" OnContent="{helpers:Loc Key=Show}"
                                                      Margin="0,4,0,4" />
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="{helpers:Loc Key=BgOverlayOpacityTitle}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14" />
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <Slider x:Name="OverlayOpacitySlider" Width="260" Minimum="0" Maximum="1"
                                        StepFrequency="0.05"
                                        Value="{x:Bind ViewModel.GlobalBackgroundOverlayOpacity, Mode=TwoWay}" />
                                <TextBlock
                                    Text="{Binding Value, ElementName=OverlayOpacitySlider, Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0:P0}'}"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="{helpers:Loc Key=FrameOpacityTitle}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14" />
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <Slider x:Name="FrameOpacitySlider" Width="260" Minimum="0" Maximum="1"
                                        StepFrequency="0.05"
                                        Value="{x:Bind ViewModel.ContentFrameBackgroundOpacity, Mode=TwoWay}" />
                                <TextBlock
                                    Text="{Binding Value, ElementName=FrameOpacitySlider, Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0:P0}'}"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>


                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="{helpers:Loc Key=BgImageOpacityTitle}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14" />
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <Slider x:Name="BgImageOpacitySlider" Width="260" Minimum="0" Maximum="1"
                                        StepFrequency="0.05"
                                        Value="{x:Bind ViewModel.GlobalBackgroundImageOpacity, Mode=TwoWay}" />
                                <TextBlock
                                    Text="{Binding Value, ElementName=BgImageOpacitySlider, Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0:P0}'}"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="{helpers:Loc Key=MinimizeToTrayTitle}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14" />
                            <ToggleSwitch OffContent="{helpers:Loc Key=Disabled}"
                                          OnContent="{helpers:Loc Key=Enabled}"
                                          IsOn="{x:Bind ViewModel.MinimizeToTray, Mode=TwoWay}" />

                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="{helpers:Loc Key=RememberWindowSizeTitle}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14" />
                            <ToggleSwitch OffContent="{helpers:Loc Key=Disabled}"
                                          OnContent="{helpers:Loc Key=Enabled}"
                                          IsOn="{x:Bind ViewModel.IsSaveWindowSizeEnabled, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,12,0,0">
                            <TextBlock Text="{helpers:Loc Key=MinWindowSizeLimitTitle}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14" />
                            <ToggleSwitch OffContent="{helpers:Loc Key=Disabled}"
                                          OnContent="{helpers:Loc Key=Enabled}"
                                          IsOn="{x:Bind ViewModel.IsMinWindowSizeLimitEnabled, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="HomeTextItem" Style="{StaticResource SettingsCardStyle}" Translation="0,0,32">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderPanelStyle}">
                            <Border Style="{StaticResource SectionAccentBarStyle}" />
                            <TextBlock Text="{helpers:Loc Key=SectionHomeText}" Style="{StaticResource SectionTitleStyle}" />
                        </StackPanel>

                        <TextBlock Text="{helpers:Loc Key=GameNewsTextColorTitle}"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   FontSize="14" />
                        <StackPanel Style="{StaticResource SettingItemStyle}" Orientation="Horizontal" Spacing="12"
                                    Margin="0,8,0,24">
                            <TextBox Header="{helpers:Loc Key=ColorHex}" Width="120"
                                     Text="{x:Bind ViewModel.GameNewsCardTextColor, Mode=TwoWay}"
                                     PlaceholderText="#FFFFFF" />
                            <StackPanel VerticalAlignment="Bottom">
                                <TextBlock Text="{helpers:Loc Key=Opacity}" Margin="0,0,0,4" />
                                <Slider Width="200" Minimum="0" Maximum="1" StepFrequency="0.05"
                                        Value="{x:Bind ViewModel.GameNewsCardTextOpacity, Mode=TwoWay}" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="{helpers:Loc Key=LaunchBtnTextColorTitle}"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   FontSize="14" />
                        <StackPanel Style="{StaticResource SettingItemStyle}" Orientation="Horizontal" Spacing="12"
                                    Margin="0,8,0,24">
                            <TextBox Header="{helpers:Loc Key=ColorHex}" Width="120"
                                     Text="{x:Bind ViewModel.LaunchButtonTextColor, Mode=TwoWay}"
                                     PlaceholderText="#FFFFFF" />
                            <StackPanel VerticalAlignment="Bottom">
                                <TextBlock Text="{helpers:Loc Key=Opacity}" Margin="0,0,0,4" />
                                <Slider Width="200" Minimum="0" Maximum="1" StepFrequency="0.05"
                                        Value="{x:Bind ViewModel.LaunchButtonTextOpacity, Mode=TwoWay}" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="{helpers:Loc Key=CheckinTextColorTitle}"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   FontSize="14" />
                        <StackPanel Style="{StaticResource SettingItemStyle}" Orientation="Horizontal" Spacing="12"
                                    Margin="0,8,0,8">
                            <TextBox Header="{helpers:Loc Key=ColorHex}" Width="120"
                                     Text="{x:Bind ViewModel.GameCheckinTextColor, Mode=TwoWay}"
                                     PlaceholderText="#FFFFFF" />
                            <StackPanel VerticalAlignment="Bottom">
                                <TextBlock Text="{helpers:Loc Key=Opacity}" Margin="0,0,0,4" />
                                <Slider Width="200" Minimum="0" Maximum="1" StepFrequency="0.05"
