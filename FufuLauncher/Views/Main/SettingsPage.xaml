                                                BorderThickness="0"
                                                VerticalAlignment="Center"
                                                Margin="0,16,0,0"
                                                Padding="4"
                                                MinWidth="0" MinHeight="0"
                                                Click="OnCommunityCheckinInfoClick">
                                            <FontIcon Glyph="&#xE946;" FontSize="15"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </Button>
                                    </StackPanel>
                                    <TextBlock Text="{helpers:Loc Key=CommunityCheckinCaption}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Opacity="0.7"
                                               Margin="0,-4,0,0" />
                                    <StackPanel Margin="32,4,0,0"
                                                Orientation="Horizontal"
                                                Visibility="{x:Bind ViewModel.IsCommunityCheckinEnabled, Mode=OneWay}">
                                        <CheckBox Content="{helpers:Loc Key=Like}"
                                                  IsChecked="{x:Bind ViewModel.IsCommunityLikeEnabled, Mode=TwoWay}"
                                                  Margin="0,0,16,0" />
                                        <CheckBox Content="{helpers:Loc Key=ReadPosts}"
                                                  IsChecked="{x:Bind ViewModel.IsCommunityReadEnabled, Mode=TwoWay}"
                                                  Margin="0,0,16,0" />
                                        <CheckBox Content="{helpers:Loc Key=Share}"
                                                  IsChecked="{x:Bind ViewModel.IsCommunityShareEnabled, Mode=TwoWay}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <ToggleSwitch Header="{helpers:Loc Key=CloudGameCheckin}"
                                                  OffContent="{helpers:Loc Key=Disabled}"
                                                  OnContent="{helpers:Loc Key=Enabled}"
                                                  IsOn="{x:Bind ViewModel.IsCloudGameCheckinEnabled, Mode=TwoWay}" />
                                    <Button Background="Transparent"
                                            BorderThickness="0"
                                            VerticalAlignment="Center"
                                            Margin="0,16,0,0"
                                            Padding="4"
                                            MinWidth="0" MinHeight="0"
                                            Click="OnCloudGameCheckinInfoClick">
                                        <FontIcon Glyph="&#xE946;" FontSize="15"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Button>
                                </StackPanel>
                                <TextBlock Text="{helpers:Loc Key=CloudGameCheckinCaption}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Opacity="0.7"
                                           Margin="0,-16,0,0" />

                                <ToggleSwitch Header="{helpers:Loc Key=AutoCheckinOnLaunch}"
                                              OffContent="{helpers:Loc Key=Disabled}"
                                              OnContent="{helpers:Loc Key=Enabled}"
                                              IsOn="{x:Bind ViewModel.IsAutoCheckinEnabled, Mode=TwoWay}" />
                                <TextBlock Text="{helpers:Loc Key=AutoCheckinCaption}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Opacity="0.7"
                                           Margin="0,-16,0,0" />

                                <ToggleSwitch Header="{helpers:Loc Key=BatchCheckin}"
                                              OffContent="{helpers:Loc Key=Disabled}"
                                              OnContent="{helpers:Loc Key=Enabled}"
                                              IsOn="{x:Bind ViewModel.IsBatchCheckinEnabled, Mode=TwoWay}" />
                                <TextBlock Text="{helpers:Loc Key=BatchCheckinCaption}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Opacity="0.7"
                                           Margin="0,-16,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,8,0,0">
                                <TextBlock Text="{helpers:Loc Key=AccountListTitle}"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                           FontSize="14"
                                           Margin="0,0,0,8" />

                                <Border CornerRadius="8"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        Padding="8"
                                        Width="500"
                                        HorizontalAlignment="Left">
                                    <ScrollViewer Height="160">
                                        <ListView ItemsSource="{x:Bind ViewModel.CheckinAccounts, Mode=OneWay}"
                                                  SelectionMode="None"
                                                  Background="Transparent">
                                            <ListView.ItemTemplate>
                                                <DataTemplate x:DataType="models:CheckinAccountItem">
                                                    <Grid Padding="0,4" ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  IsEnabled="{Binding DataContext.IsBatchCheckinEnabled, ElementName=SettingsPageRoot, Mode=OneWay}"
                                                                  VerticalAlignment="Center" />
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Nickname}" FontSize="14" />
                                                            <TextBlock Text="{Binding Uid}" FontSize="12" Opacity="0.7" />
                                                        </StackPanel>
                                                        <Button Grid.Column="2"
                                                                Click="OnCloudCredentialClick"
                                                                Tag="{Binding Uid}"
                                                                Padding="8" CornerRadius="6"
                                                                Background="Transparent"
                                                                BorderThickness="0">
                                                            <ToolTipService.ToolTip>
                                                                <ToolTip Content="{helpers:Loc Key=AddCloudCredentialTooltip}" />
                                                            </ToolTipService.ToolTip>
                                                            <Grid>
                                                                <FontIcon Glyph="&#xE753;" FontSize="14"
                                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                          Visibility="{Binding HasCloudCredential, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}" />
                                                                <FontIcon Glyph="&#xE753;" FontSize="14"
                                                                          Foreground="{ThemeResource SystemAccentColor}"
                                                                          Visibility="{Binding HasCloudCredential, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                            </Grid>
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="12,8,0,0"
                                        Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{helpers:Loc Key=CaptchaQuestion}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Opacity="0.6" VerticalAlignment="Center">
                                    <ToolTipService.ToolTip>
                                        <TextBlock Text="{helpers:Loc Key=CaptchaTooltip}"
                                                   TextWrapping="Wrap" MaxWidth="300" />
                                    </ToolTipService.ToolTip>
                                </TextBlock>
                                <HyperlinkButton Content="{helpers:Loc Key=SelfHostedVersion}"
                                                 Click="OnIndependentDeploymentClick"
                                                 FontSize="12"
                                                 Padding="0"
                                                 VerticalAlignment="Center">
                                    <ToolTipService.ToolTip>
                                        <TextBlock Text="{helpers:Loc Key=CaptchaTooltip}"
                                                   TextWrapping="Wrap" MaxWidth="300" />
                                    </ToolTipService.ToolTip>
                                </HyperlinkButton>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="AdvancedOptionsItem" Style="{StaticResource SettingsCardStyle}" Translation="0,0,32">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderPanelStyle}">
                            <Border Style="{StaticResource SectionAccentBarStyle}" />
                            <TextBlock Text="{helpers:Loc Key=SectionAdvancedOptions}" Style="{StaticResource SectionTitleStyle}" />
                        </StackPanel>

                        <ToggleSwitch Header="{helpers:Loc Key=EnableBetterGI}"
                                      OffContent="{helpers:Loc Key=Disabled}"
                                      OnContent="{helpers:Loc Key=Enabled}"
                                      IsOn="{x:Bind ViewModel.IsBetterGIIntegrationEnabled, Mode=TwoWay}"
                                      Margin="0,16,0,0" />
                        <TextBlock Text="{helpers:Loc Key=BetterGICaption}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,0,0,0" />
                        <NumberBox Header="{helpers:Loc Key=BetterGIDelayLabel}"
                                   Width="180"
                                   HorizontalAlignment="Left"
                                   Minimum="0"
                                   Maximum="60"
                                   SmallChange="0.5"
                                   LargeChange="1"
                                   SpinButtonPlacementMode="Compact"
                                   Value="{x:Bind ViewModel.BetterGIStartupDelaySeconds, Mode=TwoWay}"
                                   Margin="0,8,0,0" />
                        <TextBlock Text="{helpers:Loc Key=BetterGIDelayCaption}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,0,0,0" />

                        <ToggleSwitch Header="{helpers:Loc Key=BetterGICloseOnExit}"
                                      OffContent="{helpers:Loc Key=Disabled}"
                                      OnContent="{helpers:Loc Key=Enabled}"
                                      IsOn="{x:Bind ViewModel.IsBetterGICloseOnExitEnabled, Mode=TwoWay}"
                                      Margin="0,8,0,0" />
                        <TextBlock Text="{helpers:Loc Key=BetterGICloseOnExitCaption}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,0,0,0" />
                        <TextBlock Text="{helpers:Loc Key=BrowserCacheTitle}" Style="{ThemeResource BodyStrongTextBlockStyle}" FontSize="14"
                                   Margin="0,20,0,0" />
                        <TextBlock Text="{helpers:Loc Key=BrowserCacheCaption}" Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource SafeSecondaryTextBrush}" Margin="0,2,0,8" />
                        <StackPanel Style="{StaticResource SettingItemStyle}" Orientation="Horizontal" Spacing="16">
                            <TextBlock Text="{x:Bind ViewModel.WebView2CacheSize, Mode=OneWay}"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <Button Content="{helpers:Loc Key=ClearCacheBtn}"
                                    Command="{x:Bind ViewModel.ClearWebView2CacheCommand}"
                                    Style="{StaticResource PresetButtonStyle}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,20,0,0">
                            <TextBlock Text="{helpers:Loc Key=ProcessPriorityTitle}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14" />
                            <TextBlock Text="{helpers:Loc Key=ProcessPriorityCaption}"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.7"
                                       Margin="0,2,0,12" />

                            <ComboBox
                                SelectedIndex="{x:Bind ViewModel.AppProcessPriority, Mode=TwoWay, Converter={StaticResource EnumToIntConverter}}"
                                MinWidth="200">
                                <ComboBoxItem Content="{helpers:Loc Key=PriorityNormal}" />
                                <ComboBoxItem Content="{helpers:Loc Key=PriorityAboveNormal}" />
                                <ComboBoxItem Content="{helpers:Loc Key=High}" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Style="{StaticResource SettingItemStyle}" Margin="0,20,0,0">
                            <TextBlock Text="{helpers:Loc Key=CpuWarningTitle}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       FontSize="14" />
                            <TextBlock Text="{helpers:Loc Key=CpuWarningCaption}"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.7"
                                       Margin="0,2,0,12" />
                            <ToggleSwitch Header="{helpers:Loc Key=EnableCpuWarning}"
                                          OffContent="{helpers:Loc Key=Disabled}"
                                          OnContent="{helpers:Loc Key=Enabled}"
                                          IsOn="{x:Bind ViewModel.IsCpuUsageWarningEnabled, Mode=TwoWay}"
                                          Toggled="OnCpuUsageWarningToggled" />
                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,12,0,0"
                                        VerticalAlignment="Center">
                                <NumberBox Header="{helpers:Loc Key=CpuWarningThreshold}"
                                           Width="180"
                                           HorizontalAlignment="Left"
                                           Minimum="5"
                                           Maximum="100"
                                           SmallChange="1"
                                           LargeChange="5"
                                           SpinButtonPlacementMode="Compact"
                                           Value="{x:Bind ViewModel.CpuUsageWarningThreshold, Mode=TwoWay}" />
                                <Button Content="{helpers:Loc Key=RestoreDefault}"
                                        Command="{x:Bind ViewModel.ResetCpuUsageWarningSettingsCommand}"
                                        Style="{StaticResource PresetButtonStyle}"
                                        VerticalAlignment="Bottom" />
                            </StackPanel>
                        </StackPanel>
                        <Button HorizontalAlignment="Center"
                                Margin="0,20,0,10"
                                Padding="16,8"
                                Click="OnOpenDatabaseEditorClick">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{helpers:Loc Key=ConfigEditorBtn}" />
                            </StackPanel>
                        </Button>
                        <Button HorizontalAlignment="Center"
                                Margin="0,10,0,10"
                                Padding="16,8"
                                Click="OnOpenAchievementUpdaterClick">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{helpers:Loc Key=UpdateAchievementDbBtn}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border x:Name="ScreenshotSettingsItem" Style="{StaticResource SettingsCardStyle}" Translation="0,0,32">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderPanelStyle}">
                            <Border Style="{StaticResource SectionAccentBarStyle}" />
                            <TextBlock Text="{helpers:Loc Key=SectionScreenshotSettings}" Style="{StaticResource SectionTitleStyle}" />
                        </StackPanel>

                        <ToggleSwitch Header="{helpers:Loc Key=EnableInGameScreenshot}"
                                      OffContent="{helpers:Loc Key=Disabled}"
                                      OnContent="{helpers:Loc Key=Enabled}"
                                      IsOn="{x:Bind ViewModel.IsScreenshotEnabled, Mode=TwoWay}"
                                      Margin="0,16,0,0" />
                        <TextBlock Text="{helpers:Loc Key=ScreenshotCaption}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,0,0,0" />

                        <TextBlock Text="{helpers:Loc Key=ScreenshotHotkeyTitle}" Style="{ThemeResource BodyStrongTextBlockStyle}" FontSize="14"
                                   Margin="0,20,0,0" />
                        <TextBlock Text="{helpers:Loc Key=ScreenshotHotkeyCaption}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,2,0,8" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Name="ScreenshotHotkeyButton"
                                    Content="{x:Bind ViewModel.ScreenshotHotkey, Mode=OneWay}"
                                    Click="OnScreenshotHotkeyButtonClick"
                                    MinWidth="120"
                                    Style="{StaticResource PresetButtonStyle}" />
                            <TextBlock x:Name="HotkeyRecordingHint"
                                       Text="{helpers:Loc Key=RecordingHint}"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"
                                       Foreground="{ThemeResource SystemAccentColor}" />
                        </StackPanel>

                        <TextBlock Text="{helpers:Loc Key=ScreenshotSaveLocTitle}" Style="{ThemeResource BodyStrongTextBlockStyle}" FontSize="14"
                                   Margin="0,20,0,0" />
                        <TextBlock Text="{helpers:Loc Key=ScreenshotSaveLocCaption}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,2,0,8" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{x:Bind ViewModel.ScreenshotSavePath, Mode=OneWay}"
                                       VerticalAlignment="Center"
                                       MaxWidth="300"
                                       TextTrimming="CharacterEllipsis"
                                       Opacity="0.8" />
                            <Button Content="{helpers:Loc Key=Browse}"
                                    Command="{x:Bind ViewModel.SelectScreenshotFolderCommand}"
                                    Style="{StaticResource PresetButtonStyle}" />
                            <Button Content="{helpers:Loc Key=Clear}"
                                    Command="{x:Bind ViewModel.ClearScreenshotFolderCommand}"
                                    Visibility="{x:Bind ViewModel.HasScreenshotSavePath, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Style="{StaticResource PresetButtonStyle}" />
                        </StackPanel>

                        <Button Content="{helpers:Loc Key=OpenScreenshotFolder}"
                                Command="{x:Bind ViewModel.OpenScreenshotFolderCommand}"
                                Margin="0,16,0,0"
                                Style="{StaticResource PresetButtonStyle}" />
                    </StackPanel>
                </Border>

                <Border x:Name="UpdateItem" Style="{StaticResource SettingsCardStyle}" Translation="0,0,32">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderPanelStyle}">
                            <Border Style="{StaticResource SectionAccentBarStyle}" />
                            <TextBlock Text="{helpers:Loc Key=SectionUpdate}" Style="{StaticResource SectionTitleStyle}" />
                        </StackPanel>

                        <TextBlock Text="{helpers:Loc Key=VersionUpdateTitle}"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   FontSize="14" />
                        <TextBlock Text="{helpers:Loc Key=VersionUpdateCaption}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   Margin="0,2,0,12" />

                        <Button x:Name="CheckUpdateButton"
                                Content="{helpers:Loc Key=SectionUpdate}"
                                Command="{x:Bind ViewModel.CheckUpdateCommand}"
                                HorizontalAlignment="Left"
                                Padding="12,6"
                                CornerRadius="6" />
                    </StackPanel>
                </Border>

                <Border x:Name="AboutItem" Style="{StaticResource SettingsCardStyle}" Translation="0,0,32">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <StackPanel Spacing="10">
                        <StackPanel Style="{StaticResource SectionHeaderPanelStyle}">
                            <Border Style="{StaticResource SectionAccentBarStyle}" />
                            <TextBlock Text="{helpers:Loc Key=SectionAbout}" Style="{StaticResource SectionTitleStyle}" />
                        </StackPanel>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="FufuLauncher" Style="{ThemeResource BodyTextBlockStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="{helpers:Loc Key=AboutUsBtn}"
                                        VerticalAlignment="Center"
                                        Click="OnOpenAboutWindowClick" />
                            </Grid>
                        </Border>
                        <Button x:Name="EasterEggButton"
                                HorizontalAlignment="Center"
                                Margin="0,30,0,30"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="OnEasterEggClick"
                                ToolTipService.ToolTip="???">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEB52;" FontFamily="Segoe MDL2 Assets" Foreground="#FFB6C1" />
                                <TextBlock Text="Remember me" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border x:Name="SecurityAuthItem" Style="{StaticResource SettingsCardStyle}" Translation="0,0,32">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <StackPanel Spacing="10">
                        <StackPanel Style="{StaticResource SectionHeaderPanelStyle}">
                            <Border Style="{StaticResource SectionAccentBarStyle}" />
                            <TextBlock Text="{helpers:Loc Key=SectionSecurityAuth}" Style="{StaticResource SectionTitleStyle}" />
                        </StackPanel>
                        <TextBlock Text="{helpers:Loc Key=SecurityAuthCaption}" Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource SafeSecondaryTextBrush}" />

                        <Button Content="{helpers:Loc Key=SecurityAuthBtn}"
                                HorizontalAlignment="Left"
                                Padding="12,6"
                                CornerRadius="6"
                                Click="OnOpenSecurityAuthClick" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>