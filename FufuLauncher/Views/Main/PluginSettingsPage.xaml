<Page
    x:Class="FufuLauncher.Views.PluginSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:FufuLauncher.ViewModels"
    xmlns:selectors="using:FufuLauncher.Selectors"
    xmlns:helpers="using:FufuLauncher.Helpers"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <DataTemplate x:Key="BoolTemplate" x:DataType="viewmodels:PluginSettingItem">
            <StackPanel Width="240" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,8">
                    <TextBlock Text="{x:Bind DisplayName}" FontSize="12" Opacity="0.9" VerticalAlignment="Center"/>
                    <Button Visibility="{x:Bind HelpVisibility, Mode=OneWay}" Content="&#xE9CE;" FontFamily="Segoe Fluent Icons" FontSize="12" Width="20" Height="20" MinWidth="0" MinHeight="0" Padding="0" CornerRadius="10" Background="Transparent" BorderThickness="0" Opacity="0.5" VerticalAlignment="Center" ToolTipService.ToolTip="{helpers:Loc Key=ViewHelpTooltip}">
                        <Button.Flyout>
                            <Flyout Placement="Right">
                                <Flyout.FlyoutPresenterStyle>
                                    <Style TargetType="FlyoutPresenter">
                                        <Setter Property="Padding" Value="4"/>
                                        <Setter Property="CornerRadius" Value="8"/>
                                        <Setter Property="MaxWidth" Value="640"/>
                                        <Setter Property="MaxHeight" Value="480"/>
                                    </Style>
                                </Flyout.FlyoutPresenterStyle>
                                <Grid MinWidth="120" MinHeight="120">
                                    <ProgressRing x:Name="LoadingRing" IsActive="True" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Text="{helpers:Loc Key=GifInvalidError}" Visibility="{x:Bind GifErrorVisibility, Mode=OneWay}" Margin="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    <Image Source="{x:Bind HelpImageSource, Mode=OneWay}" Visibility="{x:Bind GifImageVisibility, Mode=OneWay}" Stretch="Uniform" ImageFailed="HelpImage_ImageFailed" ImageOpened="HelpImage_ImageOpened"/>
                                    <TextBlock x:Name="ErrorText" Text="{helpers:Loc Key=GifLoadFailedError}" Visibility="Collapsed" Margin="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                </Grid>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
                <ToggleSwitch IsOn="{x:Bind BoolValue, Mode=TwoWay}" OnContent="{helpers:Loc Key=OnLabel}" OffContent="{helpers:Loc Key=OffLabel}" MinWidth="0" Margin="0"/>
            </StackPanel>
        </DataTemplate>
        
        <DataTemplate x:Key="KeyTemplate" x:DataType="viewmodels:PluginSettingItem">
            <StackPanel Width="240" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,8">
                    <TextBlock Text="{x:Bind DisplayName}" FontSize="12" Opacity="0.9" VerticalAlignment="Center"/>
                    <Button Visibility="{x:Bind HelpVisibility, Mode=OneWay}" Content="&#xE9CE;" FontFamily="Segoe Fluent Icons" FontSize="12" Width="20" Height="20" MinWidth="0" MinHeight="0" Padding="0" CornerRadius="10" Background="Transparent" BorderThickness="0" Opacity="0.5" VerticalAlignment="Center" ToolTipService.ToolTip="{helpers:Loc Key=ViewHelpTooltip}">
                        <Button.Flyout>
                            <Flyout Placement="Right">
                                <Flyout.FlyoutPresenterStyle>
                                    <Style TargetType="FlyoutPresenter">
                                        <Setter Property="Padding" Value="4"/>
                                        <Setter Property="CornerRadius" Value="8"/>
                                        <Setter Property="MaxWidth" Value="640"/>
                                        <Setter Property="MaxHeight" Value="480"/>
                                    </Style>
                                </Flyout.FlyoutPresenterStyle>
                                <Grid MinWidth="120" MinHeight="120">
                                    <ProgressRing x:Name="LoadingRing" IsActive="True" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Text="{helpers:Loc Key=GifInvalidError}" Visibility="{x:Bind GifErrorVisibility, Mode=OneWay}" Margin="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    <Image Source="{x:Bind HelpImageSource, Mode=OneWay}" Visibility="{x:Bind GifImageVisibility, Mode=OneWay}" Stretch="Uniform" ImageFailed="HelpImage_ImageFailed" ImageOpened="HelpImage_ImageOpened"/>
                                    <TextBlock x:Name="ErrorText" Text="{helpers:Loc Key=GifLoadFailedError}" Visibility="Collapsed" Margin="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                </Grid>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
                <Grid>
                    <ComboBox ItemsSource="{x:Bind AvailableKeys}" 
                              SelectedValuePath="KeyCode" 
                              DisplayMemberPath="KeyName" 
                              SelectedValue="{x:Bind KeyValue, Mode=TwoWay}" 
                              Visibility="{x:Bind KeyListVisibility, Mode=OneWay}"
                              Width="200" HorizontalAlignment="Left"/>
                    <NumberBox Value="{x:Bind KeyNumberValue, Mode=TwoWay}"
                              SpinButtonPlacementMode="Inline"
                              SmallChange="1"
                              Minimum="1"
                              Visibility="{x:Bind KeyNumberVisibility, Mode=OneWay}"
                              Width="200" HorizontalAlignment="Left"/>
                </Grid>
            </StackPanel>
        </DataTemplate>
        
        <DataTemplate x:Key="NumberTemplate" x:DataType="viewmodels:PluginSettingItem">
            <StackPanel Width="240" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,8">
                    <TextBlock Text="{x:Bind DisplayName}" FontSize="12" Opacity="0.9" VerticalAlignment="Center"/>
                    <Button Visibility="{x:Bind HelpVisibility, Mode=OneWay}" Content="&#xE9CE;" FontFamily="Segoe Fluent Icons" FontSize="12" Width="20" Height="20" MinWidth="0" MinHeight="0" Padding="0" CornerRadius="10" Background="Transparent" BorderThickness="0" Opacity="0.5" VerticalAlignment="Center" ToolTipService.ToolTip="{helpers:Loc Key=ViewHelpTooltip}">
                        <Button.Flyout>
                            <Flyout Placement="Right">
                                <Flyout.FlyoutPresenterStyle>
                                    <Style TargetType="FlyoutPresenter">
                                        <Setter Property="Padding" Value="4"/>
                                        <Setter Property="CornerRadius" Value="8"/>
                                        <Setter Property="MaxWidth" Value="640"/>
                                        <Setter Property="MaxHeight" Value="480"/>
                                    </Style>
                                </Flyout.FlyoutPresenterStyle>
                                <Grid MinWidth="120" MinHeight="120">
                                    <ProgressRing x:Name="LoadingRing" IsActive="True" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Text="{helpers:Loc Key=GifInvalidError}" Visibility="{x:Bind GifErrorVisibility, Mode=OneWay}" Margin="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    <Image Source="{x:Bind HelpImageSource, Mode=OneWay}" Visibility="{x:Bind GifImageVisibility, Mode=OneWay}" Stretch="Uniform" ImageFailed="HelpImage_ImageFailed" ImageOpened="HelpImage_ImageOpened"/>
                                    <TextBlock x:Name="ErrorText" Text="{helpers:Loc Key=GifLoadFailedError}" Visibility="Collapsed" Margin="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                </Grid>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
                <NumberBox Value="{x:Bind FloatValue, Mode=TwoWay}" SpinButtonPlacementMode="Inline" Width="200" HorizontalAlignment="Left"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="StringTemplate" x:DataType="viewmodels:PluginSettingItem">
            <StackPanel Width="240" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,8">
                    <TextBlock Text="{x:Bind DisplayName}" FontSize="12" Opacity="0.9" VerticalAlignment="Center"/>
                    <Button Visibility="{x:Bind HelpVisibility, Mode=OneWay}" Content="&#xE9CE;" FontFamily="Segoe Fluent Icons" FontSize="12" Width="20" Height="20" MinWidth="0" MinHeight="0" Padding="0" CornerRadius="10" Background="Transparent" BorderThickness="0" Opacity="0.5" VerticalAlignment="Center" ToolTipService.ToolTip="{helpers:Loc Key=ViewHelpTooltip}">
                        <Button.Flyout>
                            <Flyout Placement="Right">
                                <Flyout.FlyoutPresenterStyle>
                                    <Style TargetType="FlyoutPresenter">
                                        <Setter Property="Padding" Value="4"/>
                                        <Setter Property="CornerRadius" Value="8"/>
                                        <Setter Property="MaxWidth" Value="640"/>
                                        <Setter Property="MaxHeight" Value="480"/>
                                    </Style>
                                </Flyout.FlyoutPresenterStyle>
                                <Grid MinWidth="120" MinHeight="120">
                                    <ProgressRing x:Name="LoadingRing" IsActive="True" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Text="{helpers:Loc Key=GifInvalidError}" Visibility="{x:Bind GifErrorVisibility, Mode=OneWay}" Margin="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    <Image Source="{x:Bind HelpImageSource, Mode=OneWay}" Visibility="{x:Bind GifImageVisibility, Mode=OneWay}" Stretch="Uniform" ImageFailed="HelpImage_ImageFailed" ImageOpened="HelpImage_ImageOpened"/>
                                    <TextBlock x:Name="ErrorText" Text="{helpers:Loc Key=GifLoadFailedError}" Visibility="Collapsed" Margin="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                </Grid>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
                <TextBox Text="{x:Bind StringValue, Mode=TwoWay}" Width="200" HorizontalAlignment="Left"/>
            </StackPanel>
        </DataTemplate>

        <selectors:SettingTemplateSelector x:Key="SettingSelector"
                                           BoolTemplate="{StaticResource BoolTemplate}"
                                           NumberTemplate="{StaticResource NumberTemplate}"
                                           StringTemplate="{StaticResource StringTemplate}"
                                           KeyTemplate="{StaticResource KeyTemplate}" />
        
        <Storyboard x:Name="EntranceStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootLayoutGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <Storyboard x:Name="ExitStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootLayoutGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid x:Name="RootLayoutGrid" Padding="32,24,32,24" Opacity="0">
        <Grid.Transitions>
            <TransitionCollection>
                <EntranceThemeTransition FromVerticalOffset="40"/>
            </TransitionCollection>
        </Grid.Transitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
                <TextBlock Text="{helpers:Loc Key=ConfigTargetLabel}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox SelectedIndex="{x:Bind ViewModel.SelectedPluginIndex, Mode=TwoWay}" Width="200">
                    <ComboBoxItem Content="{helpers:Loc Key=PluginFuFuMain}"/>
                    <ComboBoxItem Content="{helpers:Loc Key=PluginFPS}"/>
                    <ComboBoxItem Content="{helpers:Loc Key=PluginAvatar}"/>
                </ComboBox>
            </StackPanel>

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Source="/Assets/WindowIcon.ico" Width="42" Height="42" VerticalAlignment="Center" Stretch="Uniform"/>

                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.PluginName, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="{x:Bind ViewModel.PluginDescription, Mode=OneWay}" FontSize="12" Opacity="0.6" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,24,0">
                    <TextBlock Text="{x:Bind ViewModel.PluginDeveloper, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="{helpers:Loc Key=ModifiedDateLabel}" FontSize="12" Opacity="0.6"/>
                        <TextBlock Text="{x:Bind ViewModel.LastModifiedDate, Mode=OneWay}" FontSize="12" Opacity="0.6"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                    <Button Content="{helpers:Loc Key=FunctionsMenuBtn}" VerticalAlignment="Center">
                        <Button.Flyout>
                            <Flyout>
                                <StackPanel Spacing="6" MinWidth="200">
                                    <Button Content="{helpers:Loc Key=DownloadPluginBtn}" 
                                            Click="OnDownloadPluginClick" 
                                            HorizontalAlignment="Stretch"
                                            IsEnabled="{x:Bind ViewModel.IsDownloadSupported, Mode=OneWay}"/>

                                    
                                    <Button Content="{helpers:Loc Key=RepairFpsPluginBtn}" 
                                            Click="OnRepairFpsPluginClick" 
                                            HorizontalAlignment="Stretch" />
                                    
                                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4,0,4" />
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{helpers:Loc Key=MainPluginEnabledLabel}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                        <ToggleSwitch IsOn="{x:Bind ViewModel.IsMainPluginEnabled, Mode=TwoWay}" 
                                                      OnContent="{helpers:Loc Key=OnLabel}" OffContent="{helpers:Loc Key=OffLabel}" 
                                                      CornerRadius="16" 
                                                      HorizontalAlignment="Right" 
                                                      MinWidth="0" Margin="0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{helpers:Loc Key=FpsPluginEnabledLabel}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                        <ToggleSwitch IsOn="{x:Bind ViewModel.IsFpsPluginEnabled, Mode=TwoWay}" 
                                                      OnContent="{helpers:Loc Key=OnLabel}" OffContent="{helpers:Loc Key=OffLabel}" 
                                                      CornerRadius="16" 
                                                      HorizontalAlignment="Right" 
                                                      MinWidth="0" Margin="0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{helpers:Loc Key=DisableFpsAutoDisableLabel}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                        <ToggleSwitch IsOn="{x:Bind ViewModel.IsAutoDisableFpsOff, Mode=TwoWay}" 
                                                      OnContent="{helpers:Loc Key=OnLabel}" OffContent="{helpers:Loc Key=OffLabel}" 
                                                      CornerRadius="16" 
                                                      HorizontalAlignment="Right" 
                                                      MinWidth="0" Margin="0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{helpers:Loc Key=AvatarPluginEnabledLabel}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                        <ToggleSwitch IsOn="{x:Bind ViewModel.IsAvatarPluginEnabled, Mode=TwoWay}" 
                                                      OnContent="{helpers:Loc Key=OnLabel}" OffContent="{helpers:Loc Key=OffLabel}" 
                                                      CornerRadius="16" 
                                                      HorizontalAlignment="Right" 
                                                      MinWidth="0" Margin="0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{helpers:Loc Key=KeyInputModeLabel}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                        <ToggleSwitch IsOn="{x:Bind ViewModel.UseKeyListInput, Mode=TwoWay}"
                                                      OnContent="{helpers:Loc Key=ListLabel}" OffContent="{helpers:Loc Key=NumberLabel}"
                                                      CornerRadius="16"
                                                      HorizontalAlignment="Right"
                                                      MinWidth="0" Margin="0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{helpers:Loc Key=AutoCreatePresetLabel}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                        <ToggleSwitch IsOn="{x:Bind ViewModel.IsAutoCreatePresetEnabled, Mode=TwoWay}"
                                                      OnContent="{helpers:Loc Key=OnLabel}" OffContent="{helpers:Loc Key=OffLabel}"
                                                      CornerRadius="16"
                                                      HorizontalAlignment="Right"
                                                      MinWidth="0" Margin="0"/>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{helpers:Loc Key=ShowDevFeaturesLabel}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                        <ToggleSwitch IsOn="{x:Bind ViewModel.IsDevFeaturesEnabled, Mode=TwoWay}"
                                                      OnContent="{helpers:Loc Key=OnLabel}" OffContent="{helpers:Loc Key=OffLabel}"
                                                      CornerRadius="16"
                                                      HorizontalAlignment="Right"
                                                      MinWidth="0" Margin="0"/>
                                    </StackPanel>
                                    
                                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4,0,4" />
                                    <Button Content="{helpers:Loc Key=FeedbackBtn}" 
                                            Click="OnFeedbackClick" 
                                            HorizontalAlignment="Stretch"/>
                                    <Button Content="{helpers:Loc Key=SubmitPRBtn}" 
                                            Click="OnPullRequestsClick" 
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{helpers:Loc Key=EnableInjectionParenLabel}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            <TextBlock Text="{helpers:Loc Key=InjectionLoadCaption}" FontSize="11" Opacity="0.6" HorizontalAlignment="Right"/>
                        </StackPanel>
                        <ToggleSwitch IsOn="{x:Bind MainVM.UseInjection, Mode=OneWay}" 
                                      Toggled="OnInjectionToggled"
                                      OnContent="" OffContent="" MinWidth="0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <MenuFlyoutSeparator Margin="0,0,0,24"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ContentControl IsEnabled="{x:Bind ViewModel.IsSettingsInteractable, Mode=OneWay}" 
                                HorizontalContentAlignment="Stretch" 
                                VerticalContentAlignment="Stretch">
                    <StackPanel>
                        <Grid Margin="0,0,0,32" Visibility="{x:Bind ViewModel.MainSettingsVisibility, Mode=OneWay}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="{helpers:Loc Key=ConfigPresetLabel}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{x:Bind ViewModel.CurrentPreset.Name, Mode=OneWay}" FontSize="12" Opacity="0.8" VerticalAlignment="Center"/>
                            </StackPanel>

                            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{x:Bind ViewModel.AvailablePresets, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:PresetModel">
                                            <StackPanel Orientation="Horizontal" Spacing="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                                <Button Content="{x:Bind Name}" 
                                                        Click="OnSwitchPresetClick" 
                                                        Background="Transparent" 
                                                        BorderThickness="0"
                                                        ToolTipService.ToolTip="{helpers:Loc Key=SwitchPresetTooltip}"/>
                                                <TextBlock Text="{helpers:Loc Key=LockedTag}" 
                                                           Visibility="{x:Bind IsLocked, Mode=OneWay}" 
                                                           Foreground="Red" 
                                                           FontSize="12" 
                                                           VerticalAlignment="Center" 
                                                           Margin="4,0,0,0"/>
                                                <Button Content="&#xE74D;"
                                                        FontFamily="Segoe Fluent Icons" 
                                                        Click="OnDeletePresetClick"
                                                        Background="Transparent" 
                                                        Foreground="Red"
                                                        BorderThickness="0"
                                                        Width="32" Padding="0"
                                                        ToolTipService.ToolTip="{helpers:Loc Key=DeletePresetTooltip}">
                                                    <Button.Resources>
                                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="Red"/>
                                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                                                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="DarkRed"/>
                                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent"/>
                                                    </Button.Resources>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0" Spacing="8">
                                <Button Content="{helpers:Loc Key=NewPresetBtn}" Click="OnCreateNewPresetClick"/>
                                <Button Content="{helpers:Loc Key=ResetAllBtn}" Click="OnResetAllPresetsClick"/>
                            </StackPanel>
                        </Grid>

                        <GridView ItemsSource="{x:Bind ViewModel.Settings, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.MainSettingsVisibility, Mode=OneWay}"
                                  ItemTemplateSelector="{StaticResource SettingSelector}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  HorizontalAlignment="Stretch"
                                  ScrollViewer.VerticalScrollMode="Disabled">
                            <GridView.ItemContainerStyle>
                                <Style TargetType="GridViewItem">
                                    <Setter Property="Margin" Value="0,0,24,24"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="GridViewItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </GridView.ItemContainerStyle>

                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                        </GridView>
                        
                        <StackPanel Visibility="{x:Bind ViewModel.AvatarSettingsVisibility, Mode=OneWay}" Margin="0,16,0,0">
                            <TextBlock Text="{helpers:Loc Key=AvatarSettingsTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <StackPanel Orientation="Horizontal" Spacing="24">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="512x512" HorizontalAlignment="Center"/>
                                    <Border Width="128" Height="128" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                        <Image Source="{x:Bind ViewModel.Avatar512Source, Mode=OneWay}" Stretch="UniformToFill" Opacity="0" ImageOpened="AvatarPreview_ImageOpened"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                        <Button Content="{helpers:Loc Key=ImportBtn}" Tag="512" Click="OnImportAvatarClick"/>
                                        <Button Content="{helpers:Loc Key=CropBtn}" Tag="512" Click="OnEditCurrentAvatarClick" IsEnabled="{x:Bind ViewModel.HasAvatar512, Mode=OneWay}"/>
                                        <Button Content="{helpers:Loc Key=Clear}" Tag="512" Click="OnClearAvatarClick" IsEnabled="{x:Bind ViewModel.HasAvatar512, Mode=OneWay}"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="256x256" HorizontalAlignment="Center"/>
                                    <Border Width="128" Height="128" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                        <Image Source="{x:Bind ViewModel.Avatar256Source, Mode=OneWay}" Stretch="UniformToFill" Opacity="0" ImageOpened="AvatarPreview_ImageOpened"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                        <Button Content="{helpers:Loc Key=ImportBtn}" Tag="256" Click="OnImportAvatarClick"/>
                                        <Button Content="{helpers:Loc Key=CropBtn}" Tag="256" Click="OnEditCurrentAvatarClick" IsEnabled="{x:Bind ViewModel.HasAvatar256, Mode=OneWay}"/>
                                        <Button Content="{helpers:Loc Key=Clear}" Tag="256" Click="OnClearAvatarClick" IsEnabled="{x:Bind ViewModel.HasAvatar256, Mode=OneWay}"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="128x128" HorizontalAlignment="Center"/>
                                    <Border Width="128" Height="128" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                        <Image Source="{x:Bind ViewModel.Avatar128Source, Mode=OneWay}" Stretch="UniformToFill" Opacity="0" ImageOpened="AvatarPreview_ImageOpened"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                        <Button Content="{helpers:Loc Key=ImportBtn}" Tag="128" Click="OnImportAvatarClick"/>
                                        <Button Content="{helpers:Loc Key=CropBtn}" Tag="128" Click="OnEditCurrentAvatarClick" IsEnabled="{x:Bind ViewModel.HasAvatar128, Mode=OneWay}"/>
                                        <Button Content="{helpers:Loc Key=Clear}" Tag="128" Click="OnClearAvatarClick" IsEnabled="{x:Bind ViewModel.HasAvatar128, Mode=OneWay}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="{helpers:Loc Key=AvatarFormatsNote}" Margin="0,16,0,0" FontSize="12" Opacity="0.6"/>
                        </StackPanel>
                        
                    </StackPanel>
                </ContentControl>
            </ScrollViewer>
                
            <Grid x:Name="SettingsOverlay" 
                  Visibility="Collapsed" 
                  Opacity="0"
                  Margin="-16,-16,-16,0"
                  CornerRadius="8">

                <Grid.Resources>
                    <Storyboard x:Name="OverlayFadeIn">
                        <DoubleAnimation Storyboard.TargetName="SettingsOverlay" 
                                         Storyboard.TargetProperty="Opacity" 
                                         To="1" 
                                         Duration="0:0:0.25"/>
                    </Storyboard>
                    <Storyboard x:Name="OverlayFadeOut" Completed="OverlayFadeOut_Completed">
                        <DoubleAnimation Storyboard.TargetName="SettingsOverlay" 
                                         Storyboard.TargetProperty="Opacity" 
                                         To="0" 
                                         Duration="0:0:0.25"/>
                     </Storyboard>
                </Grid.Resources>

                <Grid.Background>
                    <AcrylicBrush TintColor="Transparent" 
                                  TintOpacity="0" 
                                  TintLuminosityOpacity="0" 
                                  FallbackColor="Transparent"/>
                </Grid.Background>

                <TextBlock Text="{x:Bind ViewModel.OverlayWarningText, Mode=OneWay}" 
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center" 
                           FontSize="18" 
                           FontWeight="SemiBold"/>
            </Grid>
        </Grid>
        
        <ContentDialog x:Name="CropImageDialog" 
                       Grid.RowSpan="2"
                       Title="{helpers:Loc Key=CropAvatarTitle}" 
                       PrimaryButtonText="{helpers:Loc Key=SaveCurrentSizeBtn}" 
                       SecondaryButtonText="{helpers:Loc Key=BatchApplyAllBtn}"
                       CloseButtonText="{helpers:Loc Key=CancelBtn}" 
                       PrimaryButtonClick="OnCropSaveClick"
                       SecondaryButtonClick="OnCropBatchApplyClick">
            <StackPanel Spacing="16">
                <Border Width="300" Height="300" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                    <Grid>
                        <ScrollViewer x:Name="CropScrollViewer" 
                                      Width="300" Height="300" 
                                      HorizontalScrollBarVisibility="Hidden" 
                                      VerticalScrollBarVisibility="Hidden" 
                                      HorizontalScrollMode="Enabled"
                                      VerticalScrollMode="Enabled"
                                      ZoomMode="Enabled" 
                                      MinZoomFactor="1" 
                                      MaxZoomFactor="5"
                                      PointerPressed="CropScrollViewer_PointerPressed"
                                      PointerMoved="CropScrollViewer_PointerMoved"
                                      PointerReleased="CropScrollViewer_PointerReleased"
                                      PointerWheelChanged="CropScrollViewer_PointerWheelChanged">
                            <Image x:Name="CropTargetImage" Stretch="Uniform" />
                        </ScrollViewer>
                          
                        <Grid IsHitTestVisible="False" Opacity="0.5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <Border Grid.Column="1" Grid.RowSpan="3" BorderBrush="{ThemeResource TextFillColorPrimaryBrush}" BorderThickness="1,0,1,0" Opacity="0.3" />
                            <Border Grid.Row="1" Grid.ColumnSpan="3" BorderBrush="{ThemeResource TextFillColorPrimaryBrush}" BorderThickness="0,1,0,1" Opacity="0.3" />
                        </Grid>
                    </Grid>
                </Border>
                <TextBlock Text="{helpers:Loc Key=CropHint}" FontSize="12" Opacity="0.6"/>
            </StackPanel>
        </ContentDialog>
        
    </Grid>
</Page>