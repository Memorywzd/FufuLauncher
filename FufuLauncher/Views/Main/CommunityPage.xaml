<Page
    x:Class="FufuLauncher.Views.CommunityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Margin="0"
    Padding="0">

    <Page.Resources>
        <Style x:Key="StaticIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#80000000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              Content="{TemplateBinding Content}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="0" Padding="0">
        <WebView2 x:Name="CommunityWebView" 
                  Source="https://bbs.xcnahida.cn/" 
                  HorizontalAlignment="Stretch" 
                  VerticalAlignment="Stretch"
                  Loaded="CommunityWebView_Loaded"
                  NavigationStarting="CommunityWebView_NavigationStarting"
                  NavigationCompleted="CommunityWebView_NavigationCompleted"/>

        <ProgressBar x:Name="LoadingBar" 
                     IsIndeterminate="True" 
                     VerticalAlignment="Top" 
                     Height="3"
                     Background="Transparent"
                     Foreground="{ThemeResource SystemAccentColor}"
                     Visibility="Collapsed"
                     Canvas.ZIndex="100"/>
        
        <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom" 
                    Margin="0,0,24,24" 
                    Spacing="8"
                    Canvas.ZIndex="10">
            <Button x:Name="BackButton" Click="BackButton_Click" Style="{StaticResource StaticIconButtonStyle}" ToolTipService.ToolTip="后退">
                <FontIcon Glyph="&#xE72B;" FontSize="12"/>
            </Button>
            <Button x:Name="ForwardButton" Click="ForwardButton_Click" Style="{StaticResource StaticIconButtonStyle}" ToolTipService.ToolTip="前进">
                <FontIcon Glyph="&#xE72A;" FontSize="12"/>
            </Button>
            <Button x:Name="RefreshButton" Click="RefreshButton_Click" Style="{StaticResource StaticIconButtonStyle}" ToolTipService.ToolTip="刷新">
                <FontIcon Glyph="&#xE72C;" FontSize="12"/>
            </Button>
        </StackPanel>
    </Grid>
</Page>