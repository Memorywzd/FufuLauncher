<Page
    x:Class="FufuLauncher.Views.AgreementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:FufuLauncher.Helpers"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="OnPageLoaded">

    <Page.Resources>
        <Storyboard x:Name="EntranceStoryboard">
            <DoubleAnimation Storyboard.TargetName="IconImage" Storyboard.TargetProperty="Opacity" From="0" To="1"
                             Duration="0:0:0.6" />
            <DoubleAnimation Storyboard.TargetName="IconTransform" Storyboard.TargetProperty="Y" From="30" To="0"
                             Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="TitleText" Storyboard.TargetProperty="Opacity" From="0" To="1"
                             BeginTime="0:0:0.1" Duration="0:0:0.6" />
            <DoubleAnimation Storyboard.TargetName="TitleTransform" Storyboard.TargetProperty="Y" From="30" To="0"
                             BeginTime="0:0:0.1" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="DescText" Storyboard.TargetProperty="Opacity" From="0" To="1"
                             BeginTime="0:0:0.2" Duration="0:0:0.6" />
            <DoubleAnimation Storyboard.TargetName="DescTransform" Storyboard.TargetProperty="Y" From="30" To="0"
                             BeginTime="0:0:0.2" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="AgreementArea" Storyboard.TargetProperty="Opacity" From="0" To="1"
                             BeginTime="0:0:0.3" Duration="0:0:0.6" />
            <DoubleAnimation Storyboard.TargetName="AgreementTransform" Storyboard.TargetProperty="Y" From="30" To="0"
                             BeginTime="0:0:0.3" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    Spacing="8"
                    Padding="24,16"
                    MaxWidth="650"
                    Visibility="{x:Bind ViewModel.AgreementVisibility, Mode=OneWay}">

            <Image x:Name="IconImage"
                   Source="ms-appx:///Assets/icon.png"
                   Width="52"
                   Height="52"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,2"
                   Opacity="0">
                <Image.RenderTransform>
                    <TranslateTransform x:Name="IconTransform" Y="30" />
                </Image.RenderTransform>
            </Image>

            <TextBlock x:Name="TitleText"
                       Text="{helpers:Loc Key=AgreementPage_Title}"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Opacity="0">
                <TextBlock.RenderTransform>
                    <TranslateTransform x:Name="TitleTransform" Y="30" />
                </TextBlock.RenderTransform>
            </TextBlock>

            <TextBlock x:Name="DescText"
                       Text="{helpers:Loc Key=AgreementPage_Welcome}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Opacity="0">
                <TextBlock.RenderTransform>
                    <TranslateTransform x:Name="DescTransform" Y="30" />
                </TextBlock.RenderTransform>
            </TextBlock>

            <Grid x:Name="AgreementArea" Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="AgreementTransform" Y="30" />
                </Grid.RenderTransform>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Height="220">
                    <ScrollViewer x:Name="AgreementScrollViewer" Padding="16,12" VerticalScrollBarVisibility="Auto"
                                  ViewChanged="OnAgreementScrollChanged">
                        <TextBlock Text="{x:Bind ViewModel.AgreementText, Mode=OneWay}"
                                   TextWrapping="Wrap"
                                   FontSize="12.5"
                                   LineHeight="20"
                                   IsTextSelectionEnabled="True" />
                    </ScrollViewer>
                </Border>

                <CheckBox Grid.Row="1"
                          IsChecked="{x:Bind ViewModel.IsAgreementChecked, Mode=TwoWay}"
                          IsEnabled="{x:Bind ViewModel.HasReadAgreement, Mode=OneWay}"
                          Margin="0,8,0,0"
                          Content="{helpers:Loc Key=AgreementPage_AgreeCheck}" />

                <TextBlock Grid.Row="2"
                           Text="{helpers:Loc Key=AgreementPage_ScrollHint}"
                           FontSize="11"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           Visibility="{x:Bind ViewModel.HintVisibility, Mode=OneWay}"
                           Margin="28,2,0,0" />
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="32"
                    Padding="48"
                    Visibility="{x:Bind ViewModel.IconCheckVisibility, Mode=OneWay}">

            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="20" IsStaggeringEnabled="True" />
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <Image Source="ms-appx:///Assets/icon.png"
                       Width="52" Height="52"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4" />
                <TextBlock Text="{helpers:Loc Key=AgreementPage_IconCheckHint}"
                           FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="32,24">
                <StackPanel Orientation="Horizontal" Spacing="48" HorizontalAlignment="Center">
                    <StackPanel Spacing="12">
                        <FontIcon Glyph="&#xE713;"
                                  FontSize="40"
                                  FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                  HorizontalAlignment="Center" />
                        <TextBlock Text="{helpers:Loc Key=AgreementPage_Settings}" FontSize="12" HorizontalAlignment="Center" Opacity="0.7" />
                    </StackPanel>

                    <StackPanel Spacing="12">
                        <FontIcon Glyph="&#xE80F;"
                                  FontSize="40"
                                  FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                  HorizontalAlignment="Center" />
                        <TextBlock Text="{helpers:Loc Key=AgreementPage_Home}" FontSize="12" HorizontalAlignment="Center" Opacity="0.7" />
                    </StackPanel>

                    <StackPanel Spacing="12">
                        <FontIcon Glyph="&#xE8B7;"
                                  FontSize="40"
                                  FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                  HorizontalAlignment="Center" />
                        <TextBlock Text="{helpers:Loc Key=AgreementPage_Files}" FontSize="12" HorizontalAlignment="Center" Opacity="0.7" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                <Button Content="{helpers:Loc Key=AgreementPage_CannotDisplay}"
                        Command="{x:Bind ViewModel.TroubleshootIconsCommand}"
                        Style="{StaticResource DefaultButtonStyle}"
                        MinWidth="120" />

                <Button Content="{helpers:Loc Key=AgreementPage_DisplayNormal}"
                        Command="{x:Bind ViewModel.ConfirmIconsCommand}"
                        Style="{StaticResource DefaultButtonStyle}"
                        MinWidth="120" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="24"
                    Padding="48"
                    MaxWidth="560"
                    Visibility="{x:Bind ViewModel.DataDirVisibility, Mode=OneWay}">

            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="20" IsStaggeringEnabled="True" />
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <Image Source="ms-appx:///Assets/icon.png"
                   Width="52" Height="52"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,0" />

            <TextBlock Text="{helpers:Loc Key=AgreementPage_DataStorage}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center" />

            <TextBlock Text="{helpers:Loc Key=AgreementPage_DataDirDesc}"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />

            <StackPanel Spacing="12">
                <TextBlock Text="{helpers:Loc Key=AgreementPage_UserDataDir}" FontSize="13" FontWeight="SemiBold" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{x:Bind ViewModel.DataPath, Mode=OneWay}" IsReadOnly="True"
                             FontSize="12" />
                    <Button Grid.Column="1" Content="{helpers:Loc Key=AgreementPage_Change}" Command="{x:Bind ViewModel.BrowseDataPathCommand}"
                            VerticalAlignment="Bottom" Padding="12,6" />
                </Grid>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="{helpers:Loc Key=AgreementPage_CacheDir}" FontSize="13" FontWeight="SemiBold" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{x:Bind ViewModel.CachePath, Mode=OneWay}" IsReadOnly="True"
                             FontSize="12" />
                    <Button Grid.Column="1" Content="{helpers:Loc Key=AgreementPage_Change}" Command="{x:Bind ViewModel.BrowseCachePathCommand}"
                            VerticalAlignment="Bottom" Padding="12,6" />
                </Grid>
            </StackPanel>

            <Button Content="{helpers:Loc Key=AgreementPage_ConfirmAndComplete}"
                    Command="{x:Bind ViewModel.ConfirmDataDirCommand}"
                    HorizontalAlignment="Center"
                    Padding="24,8"
                    CornerRadius="4" />

            <TextBlock Text="{x:Bind ViewModel.PathError, Mode=OneWay}"
                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Visibility="{x:Bind ViewModel.PathErrorVisibility, Mode=OneWay}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <Grid Grid.Row="1"
              Padding="20,12"
              BorderThickness="1,1,0,0"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              Visibility="{x:Bind ViewModel.AgreementVisibility, Mode=OneWay}">

            <Button Content="{helpers:Loc Key=AgreementPage_Next}"
                    Command="{x:Bind ViewModel.NextCommand}"
                    IsEnabled="{x:Bind ViewModel.IsAgreementChecked, Mode=OneWay}"
                    HorizontalAlignment="Right"
                    CornerRadius="4"
                    Padding="24,8" />
        </Grid>
    </Grid>
</Page>