<Window
    x:Class="FufuLauncher.Views.CheckinCalendarWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MihoyoBBS">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent" IsHitTestVisible="True">
            <TextBlock x:Name="TitleText" Text="签到奖励日历" VerticalAlignment="Center" Margin="16,0,0,0" FontSize="14" FontWeight="SemiBold"/>
        </Grid>

        <GridView Grid.Row="1" x:Name="CalendarGridView" Padding="16,0,16,16" SelectionMode="None" HorizontalAlignment="Center">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:CalendarRewardItem">
                    <Grid Width="72" Height="88" Margin="4" Background="#1A888888" CornerRadius="8" ToolTipService.ToolTip="{x:Bind Name}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Image Grid.Row="0" Source="{x:Bind Icon}" Stretch="Uniform" Margin="8,8,8,4"/>
                        <TextBlock Grid.Row="1" Text="{x:Bind CountText}" HorizontalAlignment="Center" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Window>